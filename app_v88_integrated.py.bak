if False and HAS_PREDICTION_ENGINE:  # 已合并，禁用旧区块
    st.markdown("---")
    st.markdown('<div style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); padding: 1.5rem; border-radius: 12px; margin: 1.5rem 0;"><h2 style="color: white; margin: 0; text-align: center; font-size: 28px;">🌍 全球市场前瞻 - AI走势预测</h2></div>', unsafe_allow_html=True)
    
    st.caption("💡 基于技术指标 + Gemini 2.5 Flash AI，预测未来3-5个交易日走势")
    
    # 添加说明
    col_btn, col_desc = st.columns([1, 2])
    with col_btn:
        run_market_analysis = st.button("🚀 启动全球市场分析", key="btn_market_forecast", type="primary", use_container_width=True)
    with col_desc:
        st.caption("⚡ 并行获取 → 技术分析 → AI预测（含完整进度显示）")
    
    if run_market_analysis:
        # 添加进度条和状态显示
        progress_bar = st.progress(0)
        status_text = st.empty()
        
        try:
            # 【V88.12优化】并行获取三大市场数据
            from concurrent.futures import ThreadPoolExecutor, as_completed
            import time
            
            status_text.text("📊 正在并行获取三大市场数据... 0%")
            progress_bar.progress(0.1)
            
            us_index_df = None
            hk_index_df = None
            cn_index_df = None
            
            # 定义获取函数
            def fetch_market_data(symbol, market_name):
                try:
                    df = fetch_stock_data(symbol)
                    if df is not None and len(df) >= 20:
                        return (market_name, df)
                    return (market_name, None)
                except Exception as e:
                    print(f"[市场数据] {market_name}获取失败: {e}")
                    return (market_name, None)
            
            # 并行获取（3个市场同时）
            markets = [
                ("^GSPC", "美股"),
                ("^HSI", "港股"),
                ("000001.SS", "A股")
            ]
            
            with ThreadPoolExecutor(max_workers=3) as executor:
                futures = {executor.submit(fetch_market_data, symbol, name): name 
                          for symbol, name in markets}
                
                completed = 0
                for future in as_completed(futures):
                    completed += 1
                    market_name, df = future.result()
                    
                    # 更新进度
                    progress = 0.1 + (completed / 3) * 0.4  # 10%-50%
                    progress_bar.progress(progress)
                    status_text.text(f"📊 {market_name}数据获取完成... {int(progress*100)}%")
                    
                    # 保存数据
                    if market_name == "美股":
                        us_index_df = df
                    elif market_name == "港股":
                        hk_index_df = df
                    elif market_name == "A股":
                        cn_index_df = df
            
            progress_bar.progress(0.5)
            status_text.text("✅ 市场数据获取完成，正在技术分析... 50%")
            
            # 运行技术分析（快速）
            progress_bar.progress(0.6)
            status_text.text("🔍 正在进行技术分析... 60%")
            
            forecaster = MarketForecaster()
            
            # 先完成技术分析
            market_results = {
                'us_market': forecaster.analyze_market_technicals(us_index_df, '美股') if us_index_df is not None else {},
                'hk_market': forecaster.analyze_market_technicals(hk_index_df, '港股') if hk_index_df is not None else {},
                'cn_market': forecaster.analyze_market_technicals(cn_index_df, 'A股') if cn_index_df is not None else {},
                'ai_forecasts': {},
                'timestamp': pd.Timestamp.now().strftime("%Y-%m-%d %H:%M:%S")
            }
            
            progress_bar.progress(0.95)
            status_text.text("✅ 技术分析完成！... 95%")
            
            # 完成基础分析
            progress_bar.progress(1.0)
            status_text.text("🎉 市场技术分析完成！")
            time.sleep(0.5)
            progress_bar.empty()
            status_text.empty()
            
            # 保存到session_state以便后续AI预测使用
            st.session_state['market_results'] = market_results
            st.session_state['forecaster'] = forecaster
        
        except Exception as e:
            st.error(f"❌ 市场分析失败: {str(e)}")
            logging.error(f"全球市场分析异常: {e}")
    
