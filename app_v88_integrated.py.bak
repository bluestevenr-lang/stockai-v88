# 【V89.1 优化】全球市场概览 - 分市场显示（美股/港股/A股）
# ═══════════════════════════════════════════════════════════════
if Config.ENABLE_EXPECTATION_LAYER:
    st.markdown('<div style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); padding: 1.5rem; border-radius: 12px; margin-bottom: 1rem;"><h2 style="color: white; margin: 0; text-align: center; font-size: 28px;">🌍 全球市场概览 (Global Market Overview)</h2><p style="color: rgba(255,255,255,0.9); margin: 0.5rem 0 0 0; text-align: center; font-size: 14px;">实时监控三大市场体制 · 把握全球资金流向</p></div>', unsafe_allow_html=True)

    try:
        # 【V89 Phase 2】检查是否请求强制刷新
        force_refresh = st.session_state.get('force_refresh_requested', False)
        if force_refresh:
            st.session_state['force_refresh_requested'] = False  # 重置标志
        
        # 启动性能监控
        _perf_monitor.start()
        
        # 【V89.1】获取所有市场分析
        all_markets = _expectation_layer.analyze_all_markets(force_refresh=force_refresh)
        
        # 【V89.2】保存到session_state供机构研究中心使用
        st.session_state.all_markets = all_markets
        
        us_result = all_markets['us_market']
        hk_result = all_markets['hk_market']
        cn_result = all_markets['cn_market']
        summary = all_markets['summary']
        
        # 顶部：全球综合状态
        st.markdown("### 🌐 全球市场综合")
        summary_col1, summary_col2, summary_col3 = st.columns([2, 1, 1])
        
        with summary_col1:
            global_verdict = summary['global_verdict']
            st.markdown(f'<div style="background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%); padding: 1rem; border-radius: 8px;"><div style="color: white; font-size: 20px; font-weight: 600;">{global_verdict}</div><div style="color: rgba(255,255,255,0.9); font-size: 14px; margin-top: 0.5rem;">{summary["global_reason"]}</div></div>', unsafe_allow_html=True)
        
        with summary_col2:
            st.metric("Risk On市场", f"{summary['risk_on_count']}/3", 
                     delta="偏好" if summary['risk_on_count'] >= 2 else None)
        
        with summary_col3:
            st.metric("Risk Off市场", f"{summary['risk_off_count']}/3",
                     delta="避险" if summary['risk_off_count'] >= 2 else None,
                     delta_color="inverse")
        
        st.divider()
        
        # 分市场展示（Tab布局）
        st.markdown("### 📊 分市场体制分析")
        market_tabs = st.tabs(["🇺🇸 美股市场", "🇭🇰 港股市场", "🇨🇳 A股市场"])
        
        # ===== 美股市场 =====
        with market_tabs[0]:
            if not us_result['data_ok']:
                st.info(f"📊 美股数据暂时不可用。原因：{us_result['reason']}")
            else:
                # 市场体制展示
                us_col1, us_col2, us_col3 = st.columns(3)
                
                with us_col1:
                    st.markdown("#### 📊 市场体制")
                    verdict = us_result['verdict']
                    if verdict == 'Risk On':
                        verdict_icon = "🟢"
                        verdict_color = "#10b981"
                        verdict_text = "Risk On（风险偏好）"
                    elif verdict == 'Risk Off':
                        verdict_icon = "🔴"
                        verdict_color = "#ef4444"
                        verdict_text = "Risk Off（风险规避）"
                    else:
                        verdict_icon = "🟡"
                        verdict_color = "#f59e0b"
                        verdict_text = "Neutral（中性观望）"
                    
                    st.markdown(f'<div style="background: {verdict_color}20; padding: 1rem; border-radius: 8px; border-left: 4px solid {verdict_color};"><div style="font-size: 28px;">{verdict_icon}</div><div style="font-size: 16px; font-weight: 600; color: {verdict_color};">{verdict_text}</div></div>', unsafe_allow_html=True)
                
                with us_col2:
                    st.markdown("#### 📈 VIX恐慌指数")
                    st.metric("当前VIX", f"{us_result['vix_level']:.2f}")
                    st.caption(us_result['vix_status'])
                
                with us_col3:
                    st.markdown("#### 🔗 股债相关性")
                    st.metric("SPY vs TLT", f"{us_result['correlation']:.2f}")
                    st.caption(us_result['corr_desc'])
                
                st.info(f"**💡 裁决依据**: {us_result['reason']}")
                
                with st.expander("📊 技术细节"):
                    tech_col1, tech_col2, tech_col3 = st.columns(3)
                    with tech_col1:
                        st.metric("SPY价格", f"${us_result['spy_price']:.2f}")
                    with tech_col2:
                        st.metric("MA50", f"${us_result['ma50']:.2f}")
                    with tech_col3:
                        st.metric("MA200", f"${us_result['ma200']:.2f}")
                
                # 【V89.2.1】美股市场前瞻分析
                if INSTITUTIONAL_RESEARCH_AVAILABLE and _institutional_research:
                    st.markdown("---")
                    st.markdown("#### 🔮 美股市场前瞻")
                    
                    # 【V89.6.7】调试信息 - 显示输入数据
                    with st.expander("🔍 调试：查看美股原始数据", expanded=False):
                        st.json({
                            'verdict': us_result.get('verdict'),
                            'spy_price': us_result.get('spy_price'),
                            'ma50': us_result.get('ma50'),
                            'ma200': us_result.get('ma200'),
                            'vix_level': us_result.get('vix_level'),
                            'data_ok': us_result.get('data_ok')
                        })
                    
                    try:
                        us_outlook = _institutional_research.analyze_market_outlook(us_result, '美股')
                        
                        # 4列展示
                        outlook_col1, outlook_col2, outlook_col3, outlook_col4 = st.columns(4)
                        
                        with outlook_col1:
                            st.metric("趋势方向", us_outlook.get('trend_direction', '未知'))
                        with outlook_col2:
                            strength = us_outlook.get('strength_score', 0)
                            st.metric("趋势强度", f"{strength}/100")
                        with outlook_col3:
                            rec = us_outlook.get('recommendation', '观望')
                            rec_icon = "🟢" if rec == '进攻' else "🔴" if rec == '防守' else "🟡"
                            st.metric("操作建议", f"{rec_icon} {rec}")
                        with outlook_col4:
                            st.metric("置信度", f"{us_outlook.get('confidence', 0)}%")
                        
                        # 关键技术位
                        key_levels = us_outlook.get('key_levels', {})
                        level_text = f"**支撑**: {key_levels.get('support_1', 'N/A')} / {key_levels.get('support_2', 'N/A')} | **阻力**: {key_levels.get('resistance_1', 'N/A')} / {key_levels.get('resistance_2', 'N/A')}"
                        st.caption(level_text)
                        
                        # 催化剂
                        catalysts = us_outlook.get('catalyst', [])
                        if catalysts:
                            st.caption(f"💡 **催化剂**: {' · '.join(catalysts[:2])}")
                    
                    except Exception as e:
                        st.caption(f"⚠️ 前瞻分析加载异常: {str(e)[:50]}")
                
                # 【V89.7 合并】美股AI走势预测（原"全球市场前瞻"内容）
                if HAS_PREDICTION_ENGINE and MY_GEMINI_KEY:
                    st.markdown("---")
                    st.markdown("#### 🤖 美股AI走势预测")
                    st.caption("基于技术指标 + Gemini 2.5 Flash，预测未来3-5个交易日走势")
                    
                    _us_pred_key = 'market_ai_us'
                    _run_us_pred = st.button("⚡ 启动美股AI预测", key="btn_us_ai_merged", type="primary", use_container_width=True)
                    
                    if _run_us_pred:
                        _prog = st.progress(0)
                        _stat = st.empty()
                        try:
                            import time as _t
                            _stat.info("📊 获取技术数据...")
                            _prog.progress(0.2)
                            _us_tech_df = fetch_stock_data("^GSPC")
                            _prog.progress(0.4)
                            _stat.info("🔍 技术分析中...")
                            _forecaster = MarketForecaster()
                            _us_tech = _forecaster.analyze_market_technicals(_us_tech_df, '美股') if _us_tech_df is not None and len(_us_tech_df) >= 20 else {}
                            _prog.progress(0.6)
                            _stat.info("🤖 Gemini AI预测中...")
                            _ai_r = _forecaster.call_gemini_market_forecast([_us_tech], MY_GEMINI_KEY)
                            st.session_state[_us_pred_key] = _ai_r.get('美股', 'AI分析结果为空')
                            st.session_state['_us_tech_data'] = _us_tech
                            _prog.progress(1.0)
                            _prog.empty()
                            _stat.empty()
                        except Exception as e:
                            _prog.empty()
                            _stat.empty()
                            st.error(f"❌ AI预测失败: {str(e)[:80]}")
                    
                    if _us_pred_key in st.session_state:
                        # 技术指标摘要
                        _us_tech_d = st.session_state.get('_us_tech_data', {})
                        if _us_tech_d:
                            _tc1, _tc2, _tc3 = st.columns(3)
                            with _tc1:
                                st.metric("当前价格", f"{_us_tech_d.get('current_price', 0):.2f}")
                            with _tc2:
                                _t_trend = _us_tech_d.get('trend', '震荡')
                                st.metric("技术趋势", _t_trend)
                            with _tc3:
                                st.metric("技术强度", f"{_us_tech_d.get('strength', 50)}/100")
                        
                        st.markdown(st.session_state[_us_pred_key])
                        if COPY_UTILS_AVAILABLE:
                            CopyUtils.create_copy_textbox(st.session_state[_us_pred_key], label="📋 复制美股AI预测", height=60)
                    else:
                        st.info("👆 点击按钮启动AI预测")
                
                # 【V89.4】美股市场舆情分析
                if SENTIMENT_ANALYZER_AVAILABLE and _sentiment_analyzer and MY_GEMINI_KEY:
                    st.markdown("---")
                    st.markdown("#### 📰 美股市场舆情")
                    
                    sentiment_us_key = "market_sentiment_us"
                    run_us_sentiment = st.button("🔍 启动美股舆情分析", key="btn_us_sentiment", use_container_width=True)
                    
                    if run_us_sentiment:
                        prompt = _sentiment_analyzer.generate_market_sentiment_prompt('美股', us_result)
                        progress_bar = st.progress(0)
                        status_text = st.empty()
                        
                        try:
                            status_text.info("📰 分析市场新闻...")
                            progress_bar.progress(0.25)
                            
                            status_text.info("💬 评估投资者情绪...")
                            progress_bar.progress(0.5)
                            
                            status_text.info("🔮 预判短期走势...")
                            progress_bar.progress(0.75)
                            
                            ai_response = call_gemini_api(prompt)
                            sentiment_metrics = _sentiment_analyzer.parse_sentiment_score(ai_response)
                            
                            st.session_state[sentiment_us_key] = {
                                'response': ai_response,
                                'metrics': sentiment_metrics
                            }
                            
                            progress_bar.progress(1.0)
                            progress_bar.empty()
                            status_text.empty()
                        
                        except Exception as e:
                            progress_bar.empty()
                            status_text.empty()
                            st.error(f"舆情分析失败: {str(e)[:60]}")
                    
                    if sentiment_us_key in st.session_state:
                        data = st.session_state[sentiment_us_key]
                        metrics = data['metrics']
                        
                        with st.expander("📊 查看舆情报告", expanded=False):
                            # 评分卡
                            s_col1, s_col2, s_col3 = st.columns(3)
                            with s_col1:
                                score = metrics.get('sentiment_score', 50)
                                color = _sentiment_analyzer.get_sentiment_color(score)
                                st.metric("舆情评分", f"{score}/100", help="0=极度负面, 100=极度正面")
                            with s_col2:
                                st.metric("情绪等级", metrics.get('sentiment_level', '中性'))
                            with s_col3:
                                st.metric("短期预判", metrics.get('short_term_impact', '震荡'))
                            
                            st.markdown("---")
                            st.markdown(data['response'])
                            if COPY_UTILS_AVAILABLE:
                                CopyUtils.create_copy_textbox(data['response'], label="📋 复制美股舆情报告", height=60)
        
        # ===== 港股市场 =====
        with market_tabs[1]:
            if not hk_result['data_ok']:
                st.info(f"📊 港股数据暂时不可用。原因：{hk_result['reason']}")
            else:
                hk_col1, hk_col2, hk_col3 = st.columns(3)
                
                with hk_col1:
                    st.markdown("#### 📊 市场体制")
                    verdict = hk_result['verdict']
                    if verdict == 'Risk On':
                        verdict_icon = "🟢"
                        verdict_color = "#10b981"
                        verdict_text = "Risk On（风险偏好）"
                    elif verdict == 'Risk Off':
                        verdict_icon = "🔴"
                        verdict_color = "#ef4444"
                        verdict_text = "Risk Off（风险规避）"
                    else:
                        verdict_icon = "🟡"
                        verdict_color = "#f59e0b"
                        verdict_text = "Neutral（中性观望）"
                    
                    st.markdown(f'<div style="background: {verdict_color}20; padding: 1rem; border-radius: 8px; border-left: 4px solid {verdict_color};"><div style="font-size: 28px;">{verdict_icon}</div><div style="font-size: 16px; font-weight: 600; color: {verdict_color};">{verdict_text}</div></div>', unsafe_allow_html=True)
                
                with hk_col2:
                    st.markdown("#### 📊 恒生指数")
                    st.metric("当前点位", f"{hk_result['index_level']:.0f}")
                    st.caption(f"MA50: {hk_result['ma50']:.0f} | MA200: {hk_result['ma200']:.0f}")
                
                with hk_col3:
                    st.markdown("#### 📈 波动率")
                    st.metric("20日年化", f"{hk_result['volatility']:.1f}%")
                    st.caption(hk_result['vol_status'])
                
                st.info(f"**💡 裁决依据**: {hk_result['reason']}")
                
                # 【V89.2.1】港股市场前瞻分析
                if INSTITUTIONAL_RESEARCH_AVAILABLE and _institutional_research:
                    st.markdown("---")
                    st.markdown("#### 🔮 港股市场前瞻")
                    
                    # 【V89.6.7】调试信息 - 显示输入数据
                    with st.expander("🔍 调试：查看港股原始数据", expanded=False):
                        st.json({
                            'verdict': hk_result.get('verdict'),
                            'index_level': hk_result.get('index_level'),
                            'ma50': hk_result.get('ma50'),
                            'ma200': hk_result.get('ma200'),
                            'volatility': hk_result.get('volatility'),
                            'data_ok': hk_result.get('data_ok')
                        })
                    
                    try:
                        hk_outlook = _institutional_research.analyze_market_outlook(hk_result, '港股')
                        
                        # 4列展示
                        outlook_col1, outlook_col2, outlook_col3, outlook_col4 = st.columns(4)
                        
                        with outlook_col1:
                            st.metric("趋势方向", hk_outlook.get('trend_direction', '未知'))
                        with outlook_col2:
                            strength = hk_outlook.get('strength_score', 0)
                            st.metric("趋势强度", f"{strength}/100")
                        with outlook_col3:
                            rec = hk_outlook.get('recommendation', '观望')
                            rec_icon = "🟢" if rec == '进攻' else "🔴" if rec == '防守' else "🟡"
                            st.metric("操作建议", f"{rec_icon} {rec}")
                        with outlook_col4:
                            st.metric("置信度", f"{hk_outlook.get('confidence', 0)}%")
                        
                        # 关键技术位
                        key_levels = hk_outlook.get('key_levels', {})
                        level_text = f"**支撑**: {key_levels.get('support_1', 'N/A')} / {key_levels.get('support_2', 'N/A')} | **阻力**: {key_levels.get('resistance_1', 'N/A')} / {key_levels.get('resistance_2', 'N/A')}"
                        st.caption(level_text)
                        
                        # 催化剂
                        catalysts = hk_outlook.get('catalyst', [])
                        if catalysts:
                            st.caption(f"💡 **催化剂**: {' · '.join(catalysts[:2])}")
                    
                    except Exception as e:
                        st.caption(f"⚠️ 前瞻分析加载异常: {str(e)[:50]}")
                
                # 【V89.7 合并】港股AI走势预测
                if HAS_PREDICTION_ENGINE and MY_GEMINI_KEY:
                    st.markdown("---")
                    st.markdown("#### 🤖 港股AI走势预测")
                    
                    _hk_pred_key = 'market_ai_hk'
                    _run_hk_pred = st.button("⚡ 启动港股AI预测", key="btn_hk_ai_merged", type="primary", use_container_width=True)
                    
                    if _run_hk_pred:
                        _prog = st.progress(0)
                        _stat = st.empty()
                        try:
                            _stat.info("📊 获取恒指数据...")
                            _prog.progress(0.2)
                            _hk_tech_df = fetch_stock_data("^HSI")
                            _prog.progress(0.4)
                            _stat.info("🔍 技术分析中...")
                            _forecaster = MarketForecaster()
                            _hk_tech = _forecaster.analyze_market_technicals(_hk_tech_df, '港股') if _hk_tech_df is not None and len(_hk_tech_df) >= 20 else {}
                            _prog.progress(0.6)
                            _stat.info("🤖 Gemini AI预测中...")
                            _ai_r = _forecaster.call_gemini_market_forecast([_hk_tech], MY_GEMINI_KEY)
                            st.session_state[_hk_pred_key] = _ai_r.get('港股', 'AI分析结果为空')
                            st.session_state['_hk_tech_data'] = _hk_tech
                            _prog.progress(1.0)
                            _prog.empty()
                            _stat.empty()
                        except Exception as e:
                            _prog.empty()
                            _stat.empty()
                            st.error(f"❌ AI预测失败: {str(e)[:80]}")
                    
                    if _hk_pred_key in st.session_state:
                        _hk_tech_d = st.session_state.get('_hk_tech_data', {})
                        if _hk_tech_d:
                            _tc1, _tc2, _tc3 = st.columns(3)
                            with _tc1:
                                st.metric("当前价格", f"{_hk_tech_d.get('current_price', 0):.2f}")
                            with _tc2:
                                st.metric("技术趋势", _hk_tech_d.get('trend', '震荡'))
                            with _tc3:
                                st.metric("技术强度", f"{_hk_tech_d.get('strength', 50)}/100")
                        st.markdown(st.session_state[_hk_pred_key])
                        if COPY_UTILS_AVAILABLE:
                            CopyUtils.create_copy_textbox(st.session_state[_hk_pred_key], label="📋 复制港股AI预测", height=60)
                    else:
                        st.info("👆 点击按钮启动AI预测")
                
                # 【V89.4】港股市场舆情分析
                if SENTIMENT_ANALYZER_AVAILABLE and _sentiment_analyzer and MY_GEMINI_KEY:
                    st.markdown("---")
                    st.markdown("#### 📰 港股市场舆情")
                    
                    sentiment_hk_key = "market_sentiment_hk"
                    run_hk_sentiment = st.button("🔍 启动港股舆情分析", key="btn_hk_sentiment", use_container_width=True)
                    
                    if run_hk_sentiment:
                        prompt = _sentiment_analyzer.generate_market_sentiment_prompt('港股', hk_result)
                        progress_bar = st.progress(0)
                        status_text = st.empty()
                        
                        try:
                            status_text.info("📰 分析市场新闻...")
                            progress_bar.progress(0.25)
                            
                            status_text.info("💬 评估投资者情绪...")
                            progress_bar.progress(0.5)
                            
                            status_text.info("🔮 预判短期走势...")
                            progress_bar.progress(0.75)
                            
                            ai_response = call_gemini_api(prompt)
                            sentiment_metrics = _sentiment_analyzer.parse_sentiment_score(ai_response)
                            
                            st.session_state[sentiment_hk_key] = {
                                'response': ai_response,
                                'metrics': sentiment_metrics
                            }
                            
                            progress_bar.progress(1.0)
                            progress_bar.empty()
                            status_text.empty()
                        
                        except Exception as e:
                            progress_bar.empty()
                            status_text.empty()
                            st.error(f"舆情分析失败: {str(e)[:60]}")
                    
                    if sentiment_hk_key in st.session_state:
                        data = st.session_state[sentiment_hk_key]
                        metrics = data['metrics']
                        
                        with st.expander("📊 查看舆情报告", expanded=False):
                            # 评分卡
                            s_col1, s_col2, s_col3 = st.columns(3)
                            with s_col1:
                                score = metrics.get('sentiment_score', 50)
                                color = _sentiment_analyzer.get_sentiment_color(score)
                                st.metric("舆情评分", f"{score}/100", help="0=极度负面, 100=极度正面")
                            with s_col2:
                                st.metric("情绪等级", metrics.get('sentiment_level', '中性'))
                            with s_col3:
                                st.metric("短期预判", metrics.get('short_term_impact', '震荡'))
                            
                            st.markdown("---")
                            st.markdown(data['response'])
                            if COPY_UTILS_AVAILABLE:
                                CopyUtils.create_copy_textbox(data['response'], label="📋 复制港股舆情报告", height=60)
        
        # ===== A股市场 =====
        with market_tabs[2]:
            if not cn_result['data_ok']:
                st.info(f"📊 A股数据暂时不可用。原因：{cn_result['reason']}")
            else:
                cn_col1, cn_col2, cn_col3 = st.columns(3)
                
                with cn_col1:
                    st.markdown("#### 📊 市场体制")
                    verdict = cn_result['verdict']
                    if verdict == 'Risk On':
                        verdict_icon = "🟢"
                        verdict_color = "#10b981"
                        verdict_text = "Risk On（风险偏好）"
                    elif verdict == 'Risk Off':
                        verdict_icon = "🔴"
                        verdict_color = "#ef4444"
                        verdict_text = "Risk Off（风险规避）"
                    else:
                        verdict_icon = "🟡"
                        verdict_color = "#f59e0b"
                        verdict_text = "Neutral（中性观望）"
                    
                    st.markdown(f'<div style="background: {verdict_color}20; padding: 1rem; border-radius: 8px; border-left: 4px solid {verdict_color};"><div style="font-size: 28px;">{verdict_icon}</div><div style="font-size: 16px; font-weight: 600; color: {verdict_color};">{verdict_text}</div></div>', unsafe_allow_html=True)
                
                with cn_col2:
                    st.markdown("#### 📊 上证指数")
                    st.metric("当前点位", f"{cn_result['index_level']:.0f}")
                    st.caption(f"MA50: {cn_result['ma50']:.0f} | MA200: {cn_result['ma200']:.0f}")
                
                with cn_col3:
                    st.markdown("#### 📈 波动率")
                    st.metric("20日年化", f"{cn_result['volatility']:.1f}%")
                    st.caption(cn_result['vol_status'])
                
                st.info(f"**💡 裁决依据**: {cn_result['reason']}")
                
                # 【V89.2.1】A股市场前瞻分析
                if INSTITUTIONAL_RESEARCH_AVAILABLE and _institutional_research:
                    st.markdown("---")
                    st.markdown("#### 🔮 A股市场前瞻")
                    
                    # 【V89.6.7】调试信息 - 显示输入数据
                    with st.expander("🔍 调试：查看A股原始数据", expanded=False):
                        st.json({
                            'verdict': cn_result.get('verdict'),
                            'index_level': cn_result.get('index_level'),
                            'ma50': cn_result.get('ma50'),
                            'ma200': cn_result.get('ma200'),
                            'volatility': cn_result.get('volatility'),
                            'data_ok': cn_result.get('data_ok')
                        })
                    
                    try:
                        cn_outlook = _institutional_research.analyze_market_outlook(cn_result, 'A股')
                        
                        # 4列展示
                        outlook_col1, outlook_col2, outlook_col3, outlook_col4 = st.columns(4)
                        
                        with outlook_col1:
                            st.metric("趋势方向", cn_outlook.get('trend_direction', '未知'))
                        with outlook_col2:
                            strength = cn_outlook.get('strength_score', 0)
                            st.metric("趋势强度", f"{strength}/100")
                        with outlook_col3:
                            rec = cn_outlook.get('recommendation', '观望')
                            rec_icon = "🟢" if rec == '进攻' else "🔴" if rec == '防守' else "🟡"
                            st.metric("操作建议", f"{rec_icon} {rec}")
                        with outlook_col4:
                            st.metric("置信度", f"{cn_outlook.get('confidence', 0)}%")
                        
                        # 关键技术位
                        key_levels = cn_outlook.get('key_levels', {})
                        level_text = f"**支撑**: {key_levels.get('support_1', 'N/A')} / {key_levels.get('support_2', 'N/A')} | **阻力**: {key_levels.get('resistance_1', 'N/A')} / {key_levels.get('resistance_2', 'N/A')}"
                        st.caption(level_text)
                        
                        # 催化剂
                        catalysts = cn_outlook.get('catalyst', [])
                        if catalysts:
                            st.caption(f"💡 **催化剂**: {' · '.join(catalysts[:2])}")
                    
                    except Exception as e:
                        st.caption(f"⚠️ 前瞻分析加载异常: {str(e)[:50]}")
                
                # 【V89.7 合并】A股AI走势预测
                if HAS_PREDICTION_ENGINE and MY_GEMINI_KEY:
                    st.markdown("---")
                    st.markdown("#### 🤖 A股AI走势预测")
                    
                    _cn_pred_key = 'market_ai_cn'
                    _run_cn_pred = st.button("⚡ 启动A股AI预测", key="btn_cn_ai_merged", type="primary", use_container_width=True)
                    
                    if _run_cn_pred:
                        _prog = st.progress(0)
                        _stat = st.empty()
                        try:
                            _stat.info("📊 获取上证数据...")
                            _prog.progress(0.2)
                            _cn_tech_df = fetch_stock_data("000001.SS")
                            _prog.progress(0.4)
                            _stat.info("🔍 技术分析中...")
                            _forecaster = MarketForecaster()
                            _cn_tech = _forecaster.analyze_market_technicals(_cn_tech_df, 'A股') if _cn_tech_df is not None and len(_cn_tech_df) >= 20 else {}
                            _prog.progress(0.6)
                            _stat.info("🤖 Gemini AI预测中...")
                            _ai_r = _forecaster.call_gemini_market_forecast([_cn_tech], MY_GEMINI_KEY)
                            st.session_state[_cn_pred_key] = _ai_r.get('A股', 'AI分析结果为空')
                            st.session_state['_cn_tech_data'] = _cn_tech
                            _prog.progress(1.0)
                            _prog.empty()
                            _stat.empty()
                        except Exception as e:
                            _prog.empty()
                            _stat.empty()
                            st.error(f"❌ AI预测失败: {str(e)[:80]}")
                    
                    if _cn_pred_key in st.session_state:
                        _cn_tech_d = st.session_state.get('_cn_tech_data', {})
                        if _cn_tech_d:
                            _tc1, _tc2, _tc3 = st.columns(3)
                            with _tc1:
                                st.metric("当前价格", f"{_cn_tech_d.get('current_price', 0):.2f}")
                            with _tc2:
                                st.metric("技术趋势", _cn_tech_d.get('trend', '震荡'))
                            with _tc3:
                                st.metric("技术强度", f"{_cn_tech_d.get('strength', 50)}/100")
                        st.markdown(st.session_state[_cn_pred_key])
                        if COPY_UTILS_AVAILABLE:
                            CopyUtils.create_copy_textbox(st.session_state[_cn_pred_key], label="📋 复制A股AI预测", height=60)
                    else:
                        st.info("👆 点击按钮启动AI预测")
                
                # 【V89.4】A股市场舆情分析
                if SENTIMENT_ANALYZER_AVAILABLE and _sentiment_analyzer and MY_GEMINI_KEY:
                    st.markdown("---")
                    st.markdown("#### 📰 A股市场舆情")
                    
                    sentiment_cn_key = "market_sentiment_cn"
                    run_cn_sentiment = st.button("🔍 启动A股舆情分析", key="btn_cn_sentiment", use_container_width=True)
                    
                    if run_cn_sentiment:
                        prompt = _sentiment_analyzer.generate_market_sentiment_prompt('A股', cn_result)
                        progress_bar = st.progress(0)
                        status_text = st.empty()
                        
                        try:
                            status_text.info("📰 分析市场新闻...")
                            progress_bar.progress(0.25)
                            
                            status_text.info("💬 评估投资者情绪...")
                            progress_bar.progress(0.5)
                            
                            status_text.info("🔮 预判短期走势...")
                            progress_bar.progress(0.75)
                            
                            ai_response = call_gemini_api(prompt)
                            sentiment_metrics = _sentiment_analyzer.parse_sentiment_score(ai_response)
                            
                            st.session_state[sentiment_cn_key] = {
                                'response': ai_response,
                                'metrics': sentiment_metrics
                            }
                            
                            progress_bar.progress(1.0)
                            progress_bar.empty()
                            status_text.empty()
                        
                        except Exception as e:
                            progress_bar.empty()
                            status_text.empty()
                            st.error(f"舆情分析失败: {str(e)[:60]}")
                    
                    if sentiment_cn_key in st.session_state:
                        data = st.session_state[sentiment_cn_key]
                        metrics = data['metrics']
                        
                        with st.expander("📊 查看舆情报告", expanded=False):
                            # 评分卡
                            s_col1, s_col2, s_col3 = st.columns(3)
                            with s_col1:
                                score = metrics.get('sentiment_score', 50)
                                color = _sentiment_analyzer.get_sentiment_color(score)
                                st.metric("舆情评分", f"{score}/100", help="0=极度负面, 100=极度正面")
                            with s_col2:
                                st.metric("情绪等级", metrics.get('sentiment_level', '中性'))
                            with s_col3:
                                st.metric("短期预判", metrics.get('short_term_impact', '震荡'))
                            
                            st.markdown("---")
                            st.markdown(data['response'])
                            if COPY_UTILS_AVAILABLE:
                                CopyUtils.create_copy_textbox(data['response'], label="📋 复制A股舆情报告", height=60)

        # 【V89.7 合并】跨市场联动摘要
        st.markdown("---")
        st.markdown("### 🌐 跨市场联动分析")
        _link_items = []
        for _mk, _mr in [('🇺🇸 美股', us_result), ('🇭🇰 港股', hk_result), ('🇨🇳 A股', cn_result)]:
            if _mr.get('data_ok'):
                _v = _mr.get('verdict', 'Unknown')
                _link_items.append(f"{_mk}：{_v}")
        if _link_items:
            st.info(" | ".join(_link_items))
            # AI联动预测缓存
            if 'market_ai_us' in st.session_state or 'market_ai_hk' in st.session_state or 'market_ai_cn' in st.session_state:
                _strong = [n for n, d in [('美股', us_result), ('港股', hk_result), ('A股', cn_result)] if d.get('data_ok') and d.get('verdict') == 'Risk On']
                _weak = [n for n, d in [('美股', us_result), ('港股', hk_result), ('A股', cn_result)] if d.get('data_ok') and d.get('verdict') == 'Risk Off']
                if _strong:
                    st.success(f"✅ 风险偏好市场：{', '.join(_strong)}")
                if _weak:
                    st.warning(f"⚠️ 避险模式市场：{', '.join(_weak)}")
        
    except Exception as e:
        # 宏观模块异常不影响主应用
        st.warning(f"⚠️  全球市场概览加载异常，主功能不受影响。错误信息: {str(e)[:100]}")
        logging.error(f"宏观仪表盘渲染异常: {e}")
        import traceback
        traceback.print_exc()

    st.markdown("---")  # 分隔线

