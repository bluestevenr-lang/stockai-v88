            analysis_summary.append(f"🇨🇳 **A股**：{cn_trend}（强度{cn_data.get('strength', 50)}/100）")
        
        if analysis_summary:
            st.markdown("\n\n".join(analysis_summary))
            
            # 简单相关性分析
            st.markdown("\n**💡 快速观察**：")
            strong_markets = []
            weak_markets = []
            
            for market_name, market_data in [('美股', us_data), ('港股', hk_data), ('A股', cn_data)]:
                if market_data and not market_data.get('error'):
                    strength = market_data.get('strength', 50)
                    if strength >= 65:
                        strong_markets.append(market_name)
                    elif strength <= 35:
                        weak_markets.append(market_name)
            
            if strong_markets:
                st.success(f"✅ 相对强势：{', '.join(strong_markets)}")
            if weak_markets:
                st.warning(f"⚠️ 相对弱势：{', '.join(weak_markets)}")
            
            st.caption("💡 提示：深度AI联动分析请点击各市场Tab中的AI预测按钮")
        else:
            st.warning("⚠️ 市场数据不足，无法进行联动分析")
    else:
        st.info("👆 点击上方按钮启动全球市场分析（含技术指标 + 完整进度显示）")
        st.caption("⚡ 优化特性：并行数据获取 + 实时进度显示 + 按需AI预测")
    
    # 添加清除缓存按钮（调试用）
    if 'market_results' in st.session_state:
        if st.button("🔄 清除市场分析缓存", key="clear_market_cache"):
            if 'market_results' in st.session_state:
                del st.session_state['market_results']
            if 'forecaster' in st.session_state:
                del st.session_state['forecaster']
            if 'market_ai_us' in st.session_state:
                del st.session_state['market_ai_us']
            if 'market_ai_hk' in st.session_state:
                del st.session_state['market_ai_hk']
            if 'market_ai_cn' in st.session_state:
                del st.session_state['market_ai_cn']
            st.rerun()

