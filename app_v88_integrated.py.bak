# 【V89 Phase 2】性能监控面板 + 强制刷新按钮
# ═══════════════════════════════════════════════════════════════
if Config.ENABLE_PERF_LAYER and Config.ENABLE_EXPECTATION_LAYER:
    st.markdown("### ⚙️ 系统性能与数据刷新")
    st.caption("💡 监控系统性能指标，管理数据缓存，确保数据时效性")
    
    try:
        # 强制刷新按钮
        col_refresh, col_info = st.columns([1, 3])
        with col_refresh:
            force_refresh_btn = st.button(
                "🔄 强制刷新市场数据", 
                key="force_refresh_macro", 
                type="secondary",
                use_container_width=True,
                help="清除所有缓存，重新获取最新市场数据"
            )
        with col_info:
            st.caption("⚡ 点击后将清除缓存，重新获取美股/港股/A股最新数据（约10-15秒）")
        
        if force_refresh_btn:
            # 设置强制刷新标志
            st.session_state['force_refresh_requested'] = True
            _cache_manager.clear()  # 清除所有缓存
            _perf_monitor.reset()  # 重置性能指标
            st.success("✅ 已触发强制刷新，正在重新获取数据...")
            st.rerun()
        
        # 性能监控面板（可折叠）
        with st.expander("⚙️ 性能监控 (Performance)", expanded=False):
            # 获取性能指标
            _perf_monitor.finalize()
            metrics = _perf_monitor.get_metrics()
            cache_stats = _cache_manager.get_stats()
            
            # 显示性能指标
            perf_col1, perf_col2, perf_col3, perf_col4 = st.columns(4)
            
            with perf_col1:
                st.metric(
                    "数据获取耗时",
                    f"{metrics['fetch_time_ms']:.0f}ms",
                    help="从数据源获取数据的总耗时"
                )
                st.metric(
                    "缓存命中率",
                    f"{_perf_monitor.get_cache_hit_ratio()*100:.1f}%",
                    help="缓存命中次数 / 总请求次数"
                )
            
            with perf_col2:
                st.metric(
                    "计算耗时",
                    f"{metrics['compute_time_ms']:.0f}ms",
                    help="指标计算和分析的总耗时"
                )
                st.metric(
                    "缓存项数量",
                    f"{cache_stats['items_count']}项",
                    help="当前缓存中的数据项数量"
                )
            
            with perf_col3:
                st.metric(
                    "渲染耗时",
                    f"{metrics['render_time_ms']:.0f}ms",
                    help="UI渲染的总耗时"
                )
                st.metric(
                    "过期兜底",
                    f"{metrics['stale_fallback_count']}次",
                    help="使用过期缓存的次数"
                )
            
            with perf_col4:
                st.metric(
                    "总耗时",
                    f"{metrics['total_time_ms']:.0f}ms",
                    help="从开始到结束的总耗时"
                )
                st.metric(
                    "错误次数",
                    f"{metrics['error_count']}次",
                    help="数据获取或计算失败的次数"
                )
            
            # 详细统计
            st.caption(f"💾 缓存大小: {cache_stats['total_size_mb']:.2f} MB")
            st.caption(f"🔍 缓存命中: {metrics['cache_hit_count']}次 | 未命中: {metrics['cache_miss_count']}次")
            
            # 性能评级
            total_time = metrics['total_time_ms']
            if total_time < 1000:
                perf_grade = "🟢 极快"
            elif total_time < 3000:
                perf_grade = "🟡 正常"
            else:
                perf_grade = "🔴 较慢"
            
            st.info(f"**性能评级**: {perf_grade} ({total_time:.0f}ms)")
    
    except Exception as e:
        # 性能面板异常不影响主应用
        st.warning(f"⚠️  性能监控面板异常: {str(e)[:80]}")
        logging.error(f"性能面板渲染异常: {e}")

# ═══════════════════════════════════════════════════════════════
else:
    logging.info("⚠️  宏观预期层已禁用 (Config.ENABLE_EXPECTATION_LAYER=False)")

