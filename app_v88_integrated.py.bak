# 【V89.7 彻底修复】确保 call_gemini_api 在所有UI代码之前已定义
# 如果模块化版本已存在（USE_NEW_MODULES=True），则不覆盖
# 如果不存在，则立即定义一个可用版本
# ═══════════════════════════════════════════════════════════════
if not USE_NEW_MODULES:
    def call_gemini_api(prompt, model_name=None):
        """Gemini API调用 - 早期定义版本（确保舆情分析等UI代码可用）"""
        try:
            if not MY_GEMINI_KEY:
                return "❌ Gemini API Key未配置"
            
            _model_name = model_name or GEMINI_MODEL_NAME
            model = genai.GenerativeModel(_model_name)
            response = model.generate_content(
                prompt,
                request_options={'timeout': 60}
            )
            return response.text
        except Exception as e:
            logging.error(f"❌ Gemini API调用失败: {str(e)}")
            return f"❌ AI分析失败: {str(e)[:100]}"
    
    logging.info("✅ call_gemini_api 早期定义完成（非模块化模式）")

# 无论哪种模式，确保舆情分析器绑定了AI调用函数
