# 11. 侧边栏 - 个股搜索入口
# ═══════════════════════════════════════════════════════════════
with st.sidebar:
    # 【V88】版本标识
    if USE_NEW_MODULES:
        st.markdown('<p style="font-size: 18px; font-weight: 700; margin-bottom: 0.5rem;">👑 AI 皇冠双核 V88</p>', unsafe_allow_html=True)
        st.caption("✨ 模块化架构 | LRU缓存")
        st.divider()
    
    # 【V87.13】缩小侧边栏标题字体
    st.markdown('<p style="font-size: 18px; font-weight: 700; margin-bottom: 1rem;">🛸 指挥控制台</p>', unsafe_allow_html=True)
    
    # 【V87.13】对比篮显示 - 缩小字体
    st.markdown('<p style="font-size: 15px; font-weight: 600; margin-top: 0.5rem; margin-bottom: 0.5rem;">⚔️ 对比篮</p>', unsafe_allow_html=True)
    if len(st.session_state.compare_basket) > 0:
        st.caption(f"📊 已选 {len(st.session_state.compare_basket)} 只股票")
        for i, (code, name) in enumerate(st.session_state.compare_basket):
            col1, col2 = st.columns([3, 1])
            with col1:
                st.markdown(f"**{i+1}.** {name} ({code})")
            with col2:
                if st.button("❌", key=f"remove_{code}_{i}", help="移除"):
                    st.session_state.compare_basket.pop(i)
                    st.rerun()
        
        col_compare, col_clear = st.columns(2)
        with col_compare:
            if st.button("⚔️ 开始对比", type="primary", use_container_width=True):
                if len(st.session_state.compare_basket) >= 2:
                    codes = [item[0] for item in st.session_state.compare_basket]
                    names = [item[1] for item in st.session_state.compare_basket]
                    st.session_state.pk_codes = codes
                    st.session_state.pk_names = names
                    st.session_state.scan_selected_code = None
                    st.session_state.scan_selected_name = None
                    st.toast(f"⚔️ 开始对比 {len(codes)} 只股票", icon="⚔️")
                    st.rerun()
                else:
                    st.warning("至少选择2只股票才能对比")
        
        with col_clear:
            if st.button("🗑️ 清空", use_container_width=True):
                st.session_state.compare_basket = []
                st.rerun()
    else:
        st.caption("💡 从搜索或扫描结果中添加股票")
    
    st.markdown("---")
    
    # 【V82.8新增】东方财富API全量搜索 - 真正的云端全量
    st.markdown('<p style="font-size: 15px; font-weight: 600; margin-top: 1rem; margin-bottom: 0.3rem;">🔍 全量云端搜索</p>', unsafe_allow_html=True)
    st.caption("💡 东方财富API：实时搜索全市场股票")
    
    # 【选框1】输入框 - 输入股票名字
    search_input = st.text_input(
        "① 输入股票名字或代码",
        placeholder="例如：宁波 / 紫金 / 腾讯 / AAPL",
        key="stock_search_input"
    )
    
    if search_input:
        search_key = search_input.strip()
        
        if search_key:
            with st.spinner("🔍 全量搜索中（东方财富API）..."):
                all_matches = []
                
                try:
                    # 【步骤1】调用东方财富搜索API
                    search_url = f"https://searchapi.eastmoney.com/api/suggest/get"
                    params = {
                        "input": search_key,
                        "type": "14",  # 14=全部股票
                        "token": "D43BF722C8E33BDC906FB84D85E326E8",
                        "count": 50  # 最多返回50个结果
                    }
                    
                    response = requests.get(search_url, params=params, timeout=5)
                    
                    if response.status_code == 200:
                        data = response.json()
                        
                        if data and 'QuotationCodeTable' in data and 'Data' in data['QuotationCodeTable']:
                            results = data['QuotationCodeTable']['Data']
                            
                            for item in results:
                                code_raw = item.get('Code', '')
                                name = item.get('Name', '')
                                market_code = item.get('MktNum', '')
                                
                                # 转换为yfinance格式
                                yf_code = None
                                if market_code == '1':  # 上海A股
                                    yf_code = f"{code_raw}.SS"
                                elif market_code == '0':  # 深圳A股
                                    yf_code = f"{code_raw}.SZ"
                                elif market_code == '116':  # 港股
                                    yf_code = f"{code_raw.zfill(5)}.HK"
                                elif market_code == '155':  # 美股
                                    yf_code = code_raw
                                else:
                                    yf_code = code_raw
                                
                                if yf_code and name:
                                    all_matches.append((yf_code, name))
                            
                            print(f"[东方财富API] 搜索 '{search_key}' 找到 {len(all_matches)} 个结果")
                    
                    # 【步骤2】如果API失败，降级到本地索引
                    if len(all_matches) == 0:
                        print("[东方财富API] 失败，降级到本地索引")
                        for code, name in STOCK_NAME_INDEX.items():
                            if (search_key.upper() in code.upper() or 
                                search_key in name or 
                                search_key.upper() in code.split('.')[0].upper()):
                                all_matches.append((code, name))
                
                except Exception as e:
                    print(f"[东方财富API] 错误: {e}")
                    # 降级到本地索引
                    for code, name in STOCK_NAME_INDEX.items():
                        if (search_key.upper() in code.upper() or 
                            search_key in name or 
                            search_key.upper() in code.split('.')[0].upper()):
                            all_matches.append((code, name))
            
            # 【步骤3】显示所有结果
            if len(all_matches) > 0:
                st.success(f"✅ 找到 {len(all_matches)} 个结果")
                
                # 【选框2】下拉选择框 - 显示所有匹配结果
                us_stocks = [(c, n) for c, n in all_matches if "." not in c]
                hk_stocks = [(c, n) for c, n in all_matches if ".HK" in c]
                cn_stocks = [(c, n) for c, n in all_matches if ".SS" in c or ".SZ" in c]
                
                options = ["请选择要分析的股票..."]
                code_map = {}
                
                if us_stocks:
                    options.append("─────── 🇺🇸 美股 ───────")
                    for code, name in us_stocks:
                        option_text = f"🇺🇸 {name} ({code})"
                        options.append(option_text)
                        code_map[option_text] = (code, name)
                
                if hk_stocks:
                    options.append("─────── 🇭🇰 港股 ───────")
                    for code, name in hk_stocks:
                        option_text = f"🇭🇰 {name} ({code})"
                        options.append(option_text)
                        code_map[option_text] = (code, name)
                
                if cn_stocks:
                    options.append("─────── 🇨🇳 A股 ───────")
                    for code, name in cn_stocks:
                        option_text = f"🇨🇳 {name} ({code})"
                        options.append(option_text)
                        code_map[option_text] = (code, name)
                
                selected_option = st.selectbox(
                    "② 从结果中选择股票",
                    options=options,
                    key="stock_select_dropdown"
                )
                
                if selected_option != "请选择要分析的股票..." and selected_option not in ["─────── 🇺🇸 美股 ───────", "─────── 🇭🇰 港股 ───────", "─────── 🇨🇳 A股 ───────"]:
                    if selected_option in code_map:
                        code, name = code_map[selected_option]
                        
                        # 【V87.7】添加到搜索历史
                        if (code, name) not in st.session_state.search_history:
                            st.session_state.search_history.insert(0, (code, name))
                            if len(st.session_state.search_history) > 10:  # 最多保留10条
                                st.session_state.search_history = st.session_state.search_history[:10]
                        
                        col_analyze, col_compare = st.columns(2)
                        
                        with col_analyze:
                            if st.button("🚀 立即分析", key="search_analyze", type="primary", use_container_width=True):
                                st.session_state.scan_selected_code = code
                                st.session_state.scan_selected_name = name
                                st.session_state.pk_codes = []
                                st.session_state.pk_names = []
                                st.toast(f"✅ 已选中 {name}", icon="🎯")
                                st.rerun()
                        
                        with col_compare:
                            # 【V87.7】加入对比按钮
                            is_in_basket = (code, name) in st.session_state.compare_basket
                            if is_in_basket:
                                if st.button("✅ 已加入", key="search_compare", disabled=True, use_container_width=True):
                                    pass
                            else:
                                if st.button("➕ 加入对比", key="search_compare", use_container_width=True):
                                    st.session_state.compare_basket.append((code, name))
                                    st.toast(f"✅ 已加入对比篮: {name}", icon="➕")
                                    st.rerun()
            else:
                st.warning("❌ 未找到匹配的股票")
                st.caption("💡 搜索提示：")
                st.caption("• 关键字：宁波、紫金、腾讯")
                st.caption("• 代码：AAPL、02899、600519")
    
    # 【V87.7】搜索历史
    if len(st.session_state.search_history) > 0:
        st.markdown('<p style="font-size: 14px; font-weight: 600; margin-top: 1rem; margin-bottom: 0.3rem;">📜 搜索历史</p>', unsafe_allow_html=True)
        st.caption(f"最近搜索 {len(st.session_state.search_history)} 只")
        
        for i, (code, name) in enumerate(st.session_state.search_history):
            col1, col2, col3 = st.columns([2, 1, 1])
            
            with col1:
                st.markdown(f"**{name}**")
                st.caption(code)
            
            with col2:
                if st.button("🔍", key=f"hist_analyze_{i}", help="分析", use_container_width=True):
                    st.session_state.scan_selected_code = code
                    st.session_state.scan_selected_name = name
                    st.session_state.pk_codes = []
                    st.session_state.pk_names = []
                    st.rerun()
            
            with col3:
                is_in_basket = (code, name) in st.session_state.compare_basket
                if is_in_basket:
                    st.button("✅", key=f"hist_compare_{i}", disabled=True, use_container_width=True)
                else:
                    if st.button("➕", key=f"hist_compare_{i}", help="加入对比", use_container_width=True):
                        st.session_state.compare_basket.append((code, name))
                        st.toast(f"✅ 已加入对比篮: {name}", icon="➕")
                        st.rerun()
        
        if st.button("🗑️ 清空历史", use_container_width=True):
            st.session_state.search_history = []
            st.rerun()
    
    st.divider()
    
    # 代理设置
    st.markdown('<p style="font-size: 15px; font-weight: 600; margin-top: 1rem; margin-bottom: 0.3rem;">⚙️ 网络设置</p>', unsafe_allow_html=True)
    proxy_port = st.text_input("本地代理端口", value="1082", key="proxy_port_input")
    st.session_state.proxy_port = (proxy_port or "1082").strip() or "1082"
    
    if st.button("测试连接", use_container_width=True):
        purl = f"http://127.0.0.1:{st.session_state.proxy_port}"
        try:
            with ProxyContext(purl):
                r = requests.get("https://www.google.com", timeout=5, verify=False)
            st.success(f"✅ Google: {r.status_code}")
        except Exception as e:
            st.error(f"❌ 连接失败: {type(e).__name__}")
    
    st.divider()
    
    # 【V88】缓存统计显示
    if USE_NEW_MODULES:
        st.markdown('<p style="font-size: 15px; font-weight: 600; margin-top: 1rem; margin-bottom: 0.3rem;">💾 缓存状态 (V88 LRU)</p>', unsafe_allow_html=True)
        cache_stats = local_cache.get_stats()
        if cache_stats:
            st.metric(
                "缓存使用",
                f"{cache_stats['total_size_mb']:.1f}MB",
                f"{cache_stats['usage_percent']:.1f}%"
            )
            st.caption(f"📁 文件数: {cache_stats['file_count']} | ⏱️ TTL: {cache_stats['ttl_seconds']}s")
            st.caption(f"🔄 策略: LRU淘汰（保持80%容量）")
        st.divider()
    
    # 【V87.8】系统自检和股票池清理
    st.markdown('<p style="font-size: 15px; font-weight: 600; margin-top: 1rem; margin-bottom: 0.3rem;">🛠️ 系统维护</p>', unsafe_allow_html=True)
    st.caption("💡 诊断系统状态")
    
    col1, col2 = st.columns(2)
    with col1:
        if st.button("🛠️ 系统诊断", use_container_width=True, type="secondary"):
            with st.spinner("正在执行系统诊断..."):
                diagnostic_result = run_system_diagnostic()
            
            # 显示结果
            st.markdown("#### 诊断结果")
    
    with col2:
        if st.button("🏥 股票池检查", use_container_width=True, type="secondary"):
            with st.spinner("正在检查股票池健康状况..."):
                us_pool, hk_pool, cn_pool = init_stock_pools()
                
                st.markdown("#### 股票池健康检查结果")
                
                # 检查各市场股票池
                us_invalid = validate_stock_pool_health(us_pool, "美股", max_test=3)
                hk_invalid = validate_stock_pool_health(hk_pool, "港股", max_test=3) 
                cn_invalid = validate_stock_pool_health(cn_pool, "A股", max_test=3)
                
                total_invalid = len(us_invalid) + len(hk_invalid) + len(cn_invalid)
                if total_invalid == 0:
                    st.success("✅ 所有测试的股票代码都能正常获取数据")
                else:
                    st.warning(f"⚠️ 发现 {total_invalid} 个问题代码，建议更新股票池")
    
    # 【V87.15 + V88】缓存管理
    st.markdown('<p style="font-size: 15px; font-weight: 600; margin-top: 1rem; margin-bottom: 0.3rem;">💾 缓存管理</p>', unsafe_allow_html=True)
    
    cache_stats = local_cache.get_stats()
    st.caption(f"📊 缓存使用: {cache_stats['total_size_mb']:.1f}MB / {cache_stats['max_size_mb']:.0f}MB ({cache_stats['usage_percent']:.1f}%)")
    st.caption(f"📁 缓存文件: {cache_stats['file_count']} 个 | ⏱️ 有效期: 10分钟")
    
    # 【V87.15】容量警告
    if cache_stats['usage_percent'] > 90:
        st.warning(f"⚠️ 缓存即将满，达到{cache_stats['max_size_mb']:.0f}MB后将自动清零", icon="⚠️")
    
    col_cache1, col_cache2 = st.columns(2)
    with col_cache1:
        if st.button("🗑️ 清空缓存", use_container_width=True, help="清空所有本地缓存文件"):
            local_cache.clear_all()
            st.cache_data.clear()
            st.success("✅ 缓存已清空")
            st.rerun()
    
    with col_cache2:
        if st.button("📋 查看失败详情", use_container_width=True):
            st.session_state.show_failed_stocks = True
            st.rerun()
    
    # 原有的诊断结果显示逻辑
    if 'diagnostic_result' in locals():
        
        # 1. 网络连通性
        net = diagnostic_result['network']
        if net['status'] == 'ok':
            st.success(f"✅ **网络连通性**: {net['message']}")
        elif net['status'] == 'warning':
            st.warning(f"⚠️ **网络连通性**: {net['message']}")
        else:
            st.error(f"❌ **网络连通性**: {net['message']}")
        
        # 2. 数据源测试
        st.markdown("**数据源测试**:")
        for market, result in diagnostic_result['data_sources'].items():
            if result['status'] == 'ok':
                st.success(f"✅ {result['name']}: {result['message']} (最后日期: {result.get('last_date', 'N/A')})")
            elif result['status'] == 'warning':
                st.warning(f"⚠️ {result['name']}: {result['message']}")
            else:
                st.error(f"❌ {result['name']}: {result['message']}")
        
        # 3. 整体评估
        st.divider()
        overall = diagnostic_result['overall']
        if overall == 'healthy':
            st.success("🎉 **系统状态**: 一切正常，可以开始使用！")
        elif overall == 'warning':
            st.warning("⚠️ **系统状态**: 部分功能可能受限，但基本可用")
        else:
            st.error("❌ **系统状态**: 存在严重问题，请检查网络和代理设置")
    
    st.divider()
    
    # 【V87】刷新股票池
    st.markdown("### 🔄 股票池管理")
    col_pool1, col_pool2 = st.columns(2)
    
    with col_pool1:
        if st.button("🔄 刷新股票池", use_container_width=True, help="重新从云端获取最新股票列表"):
            with st.spinner("正在刷新股票池..."):
                # 清除缓存
                st.cache_data.clear()
                # 重新加载
                st.rerun()
    
    with col_pool2:
        if st.button("🗑️ 清除全部缓存", use_container_width=True):
            st.cache_data.clear()
            st.success("✅ 缓存已清除")
            time.sleep(0.5)
            st.rerun()

# ═══════════════════════════════════════════════════════════════
# 12. 主界面 - 标题（修复遮挡）
# ═══════════════════════════════════════════════════════════════
st.markdown(
    '<div style="text-align: center; margin-bottom: 1.5rem;"><h2 style="color: #1e3a8a; font-size: 24px; font-weight: 700; margin: 0;">👑 AI 皇冠双核 V88 (模块化架构)</h2></div>',
    unsafe_allow_html=True
)

# ═══════════════════════════════════════════════════════════════
# 【V89.8 布局重构】模块分隔函数
# ═══════════════════════════════════════════════════════════════
def _module_header(icon, title, subtitle="", color_from="#667eea", color_to="#764ba2"):
    """统一的模块标题样式 - 清晰的视觉边界"""
    sub_html = f'<p style="color: rgba(255,255,255,0.85); margin: 0.3rem 0 0 0; text-align: center; font-size: 12px;">{subtitle}</p>' if subtitle else ''
    st.markdown(f'''<div style="background: linear-gradient(135deg, {color_from} 0%, {color_to} 100%); 
        padding: 1.2rem; border-radius: 10px; margin: 1.5rem 0 1rem 0;">
        <h3 style="color: white; margin: 0; text-align: center; font-size: 22px;">{icon} {title}</h3>
        {sub_html}
    </div>''', unsafe_allow_html=True)

# ═══════════════════════════════════════════════════════════════
# 13. 环球行业热力图
# ═══════════════════════════════════════════════════════════════
col_title, col_refresh = st.columns([4, 1])
with col_title:
    st.markdown('<h3 style="color: #374151; font-size: 20px; font-weight: 600; margin-bottom: 0.8rem;">🌎 环球行业热力 (Daily)</h3>', unsafe_allow_html=True)
with col_refresh:
    if st.button("🔄", key="refresh_heat", help="刷新数据"):
        st.cache_data.clear()
        st.rerun()

@st.cache_data(ttl=CACHE_TTL)
def get_market_heat():
    """【V87.7】环球行业热力图 + 分市场资金走向"""
    SECTORS = {
        "科技": {"US": "NVDA", "HK": "00700", "CN": "601138.SH"},
        "健康护理": {"US": "JNJ", "HK": "02269", "CN": "600276.SH"},
        "公用事业": {"US": "NEE", "HK": "00002", "CN": "600900.SH"},
        "通信": {"US": "T", "HK": "00941", "CN": "600050.SH"},
        "金融": {"US": "JPM", "HK": "02318", "CN": "600036.SH"},
        "工业": {"US": "CAT", "HK": "00992", "CN": "601766.SH"},
        "非必需消费": {"US": "TSLA", "HK": "03690", "CN": "002594.SZ"},
        "必需消费": {"US": "WMT", "HK": "09633", "CN": "600519.SH"},
        "原材料": {"US": "LIN", "HK": "02899", "CN": "601899.SH"},
        "房地产": {"US": "PLD", "HK": "00016", "CN": "000002.SZ"}
    }
    
    results = []
    for sector_name, markets in SECTORS.items():
        row = {
            "行业": sector_name,
            # 【V87.9】添加隐藏的代码列，用于点击分析
            "_us_code": markets["US"],
            "_hk_code": markets["HK"],
            "_cn_code": markets["CN"]
        }
        
        # 【V87.7】为每个市场分别计算资金走向
        market_trends = {
            "US": {"5d": None, "30d": None, "60d": None},
            "HK": {"5d": None, "30d": None, "60d": None},
            "CN": {"5d": None, "30d": None, "60d": None}
        }
        
        for market_key, market_label, code_raw in [
            ("US", "🇺🇸 美股", markets["US"]), 
            ("HK", "🇭🇰 港股", markets["HK"]), 
            ("CN", "🇨🇳 A股", markets["CN"])
        ]:
            try:
                # 【V75关键】强制代码转换
                code_fixed = to_yf_cn_code(code_raw)
                print(f"[热力图] {sector_name} {market_label}: {code_raw} -> {code_fixed}")
                
                df = fetch_stock_data(code_fixed)
                
                # 【V85】如果数据为空,打印失败信息
                if df is None or df.empty:
                    print(f"[热力图] ❌ {sector_name} {market_label} ({code_raw}) 获取失败: 返回空数据")
                
                if df is not None and len(df) > 60:
                    last_price = df['Close'].iloc[-1]
                    ma60 = df['Close'].rolling(60).mean().iloc[-1]
                    
                    # 【V87.9】配置状态 - 超配改为蓝色，标配改为绿色
                    if pd.notna(ma60) and pd.notna(last_price) and ma60 > 0:
                        if last_price > ma60 * 1.05:
                            status = "🔵 超配"  # 改为蓝色
                        elif last_price > ma60:
                            status = "🟢 标配"  # 保持绿色
                        elif last_price > ma60 * 0.95:
                            status = "🟡 观望"
                        else:
                            status = "🔴 低配"
                    else:
                        status = "⚪ 计算失败"
                    
                    # 【V87.7】计算该市场的资金走向
                    if len(df) >= 5:
                        market_trends[market_key]["5d"] = ((df['Close'].iloc[-1] - df['Close'].iloc[-5]) / df['Close'].iloc[-5]) * 100
                    
                    if len(df) >= 30:
                        market_trends[market_key]["30d"] = ((df['Close'].iloc[-1] - df['Close'].iloc[-30]) / df['Close'].iloc[-30]) * 100
                    
                    if len(df) >= 60:
                        market_trends[market_key]["60d"] = ((df['Close'].iloc[-1] - df['Close'].iloc[-60]) / df['Close'].iloc[-60]) * 100
                    
                elif df is not None and len(df) > 20:
                    last_price = df['Close'].iloc[-1]
                    ma60 = df['Close'].rolling(60).mean().iloc[-1]
                    if pd.notna(ma60) and pd.notna(last_price) and ma60 > 0:
                        if last_price > ma60 * 1.05:
                            status = "🔵 超配"  # 改为蓝色
                        elif last_price > ma60:
                            status = "🟢 标配"  # 保持绿色
                        elif last_price > ma60 * 0.95:
                            status = "🟡 观望"
                        else:
                            status = "🔴 低配"
                    else:
                        status = "⚪ 计算失败"
                else:
                    status = "⚪ 无数据"
            except Exception as e:
                print(f"[热力图] ❌ {code_raw}: {type(e).__name__}")
                status = "⚪ 异常"
            row[market_label] = status
        
        # 【V87.10】优化显示：配置状态 + 资金走向（不带日期标签，放到列标题）
        # 美股：配置 + 5日/30日/60日
        us_status = row.get("🇺🇸 美股", "⚪")
        us_5d = market_trends["US"]["5d"]
        us_30d = market_trends["US"]["30d"]
        us_60d = market_trends["US"]["60d"]
        us_trend_str = " | ".join([
            f"{'↑' if us_5d and us_5d > 0 else '↓'}{us_5d:+.1f}%" if us_5d is not None else "N/A",
            f"{'↑' if us_30d and us_30d > 0 else '↓'}{us_30d:+.1f}%" if us_30d is not None else "N/A",
            f"{'↑' if us_60d and us_60d > 0 else '↓'}{us_60d:+.1f}%" if us_60d is not None else "N/A"
        ])
        row["🇺🇸 美股 5日 | 30日 | 60日"] = f"{us_status} {us_trend_str}"
        
        # 港股：配置 + 5日/30日/60日
        hk_status = row.get("🇭🇰 港股", "⚪")
        hk_5d = market_trends["HK"]["5d"]
        hk_30d = market_trends["HK"]["30d"]
        hk_60d = market_trends["HK"]["60d"]
        hk_trend_str = " | ".join([
            f"{'↑' if hk_5d and hk_5d > 0 else '↓'}{hk_5d:+.1f}%" if hk_5d is not None else "N/A",
            f"{'↑' if hk_30d and hk_30d > 0 else '↓'}{hk_30d:+.1f}%" if hk_30d is not None else "N/A",
            f"{'↑' if hk_60d and hk_60d > 0 else '↓'}{hk_60d:+.1f}%" if hk_60d is not None else "N/A"
        ])
        row["🇭🇰 港股 5日 | 30日 | 60日"] = f"{hk_status} {hk_trend_str}"
        
        # A股：配置 + 5日/30日/60日
        cn_status = row.get("🇨🇳 A股", "⚪")
        cn_5d = market_trends["CN"]["5d"]
        cn_30d = market_trends["CN"]["30d"]
        cn_60d = market_trends["CN"]["60d"]
        cn_trend_str = " | ".join([
            f"{'↑' if cn_5d and cn_5d > 0 else '↓'}{cn_5d:+.1f}%" if cn_5d is not None else "N/A",
            f"{'↑' if cn_30d and cn_30d > 0 else '↓'}{cn_30d:+.1f}%" if cn_30d is not None else "N/A",
            f"{'↑' if cn_60d and cn_60d > 0 else '↓'}{cn_60d:+.1f}%" if cn_60d is not None else "N/A"
        ])
        row["🇨🇳 A股 5日 | 30日 | 60日"] = f"{cn_status} {cn_trend_str}"
        
        results.append(row)
    
    print(f"[热力图] 扫描完成")
    return pd.DataFrame(results)

# 【V87.10】可点击的热力图 - 优化列标题
heat_df = get_market_heat()

# 显示热力图（隐藏代码列，使用新的列名）
display_cols = ["行业", "🇺🇸 美股 5日 | 30日 | 60日", "🇭🇰 港股 5日 | 30日 | 60日", "🇨🇳 A股 5日 | 30日 | 60日"]
selected_heat = st.dataframe(
    heat_df[display_cols],
    use_container_width=True,
    hide_index=True,
    on_select="rerun",
    selection_mode="single-row",
    key="heat_table"
)

# 【V87.11】处理热力图点击事件 - AI行业分析
if selected_heat and len(selected_heat.selection.rows) > 0:
    selected_idx = selected_heat.selection.rows[0]
    selected_row = heat_df.iloc[selected_idx]
    sector_name = selected_row["行业"]
    
    # 显示选择对话框
    st.info(f"📊 您选择了 **{sector_name}** 行业，请选择要分析的市场：")
    
    col1, col2, col3 = st.columns(3)
    with col1:
        if st.button(f"🇺🇸 分析美股 {sector_name}", key="analyze_us_sector", use_container_width=True, type="primary"):
            # 【V87.11】触发AI行业分析
            st.session_state.sector_analysis_name = sector_name
            st.session_state.sector_analysis_market = "美股"
            st.session_state.sector_analysis_codes = {
                "us": selected_row["_us_code"],
                "hk": selected_row["_hk_code"],
                "cn": selected_row["_cn_code"]
            }
            st.toast(f"🚀 AI分析美股 {sector_name} 行业中...", icon="🇺🇸")
            st.rerun()
    
    with col2:
        if st.button(f"🇭🇰 分析港股 {sector_name}", key="analyze_hk_sector", use_container_width=True, type="primary"):
            # 【V87.11】触发AI行业分析
            st.session_state.sector_analysis_name = sector_name
            st.session_state.sector_analysis_market = "港股"
            st.session_state.sector_analysis_codes = {
                "us": selected_row["_us_code"],
                "hk": selected_row["_hk_code"],
                "cn": selected_row["_cn_code"]
            }
            st.toast(f"🚀 AI分析港股 {sector_name} 行业中...", icon="🇭🇰")
            st.rerun()
    
    with col3:
        if st.button(f"🇨🇳 分析A股 {sector_name}", key="analyze_cn_sector", use_container_width=True, type="primary"):
            # 【V87.11】触发AI行业分析
            st.session_state.sector_analysis_name = sector_name
            st.session_state.sector_analysis_market = "A股"
            st.session_state.sector_analysis_codes = {
                "us": selected_row["_us_code"],
                "hk": selected_row["_hk_code"],
                "cn": selected_row["_cn_code"]
            }
            st.toast(f"🚀 AI分析A股 {sector_name} 行业中...", icon="🇨🇳")
            st.rerun()

# 【V87.11】显示AI行业分析结果
if 'sector_analysis_name' in st.session_state and st.session_state.sector_analysis_name:
    sector_name = st.session_state.sector_analysis_name
    market = st.session_state.sector_analysis_market
    
    st.markdown("---")
    st.markdown(f"## 🏭 {market} {sector_name}行业 AI深度分析")
    
    if st.button("❌ 关闭行业分析", key="close_sector_analysis"):
        st.session_state.sector_analysis_name = None
        st.session_state.sector_analysis_market = None
        st.session_state.sector_analysis_codes = None
        st.rerun()
    
    # 【V87.11】检查Gemini是否可用
    if not HAS_GEMINI:
        st.error("❌ 未安装 google-generativeai 库")
        st.info("💡 请运行: pip install google-generativeai")
    elif not MY_GEMINI_KEY:
        st.error("❌ 未配置 Gemini API Key")
        st.info("💡 请在 .streamlit/secrets.toml 中配置 GEMINI_API_KEY")
    else:
        with st.spinner(f"Gemini正在分析{market}{sector_name}行业..."):
            # 获取行业代表股票的数据
            codes = st.session_state.sector_analysis_codes
            market_code = codes["us"] if market == "美股" else (codes["hk"] if market == "港股" else codes["cn"])
            
            # 获取股票数据用于分析
            df = fetch_stock_data(to_yf_cn_code(market_code))
            
            # 构建AI分析prompt
            from datetime import datetime
            today = datetime.now().strftime("%Y年%m月%d日")
            
            prompt = f"""请作为资深行业分析师，深度分析{market}{sector_name}行业的投资机会。

【分析日期】{today}
【目标市场】{market}
【目标行业】{sector_name}

请按以下结构输出专业分析报告（800-1000字）：

## 📊 行业概况
- 当前{market}{sector_name}行业的整体态势
- 行业在当前市场环境中的地位和重要性

## 📰 行业新闻与热点
- 列举2-3条近期{sector_name}行业的重要新闻或事件
- 分析这些新闻对行业的影响

## 📈 趋势分析
- 短期趋势（1-3个月）：技术面、资金面分析
- 中期趋势（3-6个月）：基本面、政策面分析
- 长期趋势（6-12个月）：行业发展方向

## 🎯 投资预测
- 看多/看空/中性的判断及理由
- 关键支撑位和阻力位
- 风险提示

## 💼 推荐个股（{market}市场）
请推荐3-5只{market}{sector_name}行业的优质个股：
- 股票名称和代码
- 推荐理由（2-3句话）
- 目标价位或预期涨幅

要求：
1. 语言专业但易懂
2. 数据支撑观点
3. 客观中立，不夸大
4. 不要称呼语和结尾废话
"""
            
            try:
                # 调用Gemini API
                model = genai.GenerativeModel(GEMINI_MODEL_NAME)
                response = model.generate_content(prompt)
                analysis_text = response.text
                
                # 显示分析结果
                st.markdown(f"""
<style>
.sector-analysis {{
    font-size: 14px;
    line-height: 1.8;
    color: #1f2937;
}}
.sector-analysis h2 {{
    font-size: 18px;
