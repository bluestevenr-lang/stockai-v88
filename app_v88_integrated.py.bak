    color: #4b5563;
}}
</style>
<div class="sector-analysis">

{analysis_text}

</div>
""", unsafe_allow_html=True)
                
            except Exception as e:
                st.error(f"❌ AI分析失败: {type(e).__name__}: {str(e)}")
                st.info("💡 请检查Gemini API配置或网络连接")

