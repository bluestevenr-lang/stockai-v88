# 13.5 【V82极简方案】全局函数定义 - 复选框智能识别
# ═══════════════════════════════════════════════════════════════
def render_clickable_table(df_results, table_key):
    """【V87.7】复选框智能识别 + 加入对比篮"""
    if df_results is None or len(df_results) == 0:
        st.info("暂无数据")
        return
    
    if isinstance(df_results, list):
        df_results = pd.DataFrame(df_results)
    
    if "代码" not in df_results.columns:
        st.dataframe(df_results, use_container_width=True, hide_index=True)
        return
    
    # 添加复选框列到数据框
    df_display = df_results.copy()
    
    st.markdown("##### 📊 扫描结果")
    st.caption("💡 提示：勾选1只=深度分析 | 勾选2只以上=立即对比 | 或点击下方按钮加入对比篮")
    
    # 使用 on_select 实现复选框交互
    selection = st.dataframe(
        df_display,
        use_container_width=True,
        hide_index=True,
        on_select="rerun",
        selection_mode="multi-row",  # 多行选择模式
        key=f"table_{table_key}"
    )
    
    # 【V87.15修复】处理选中事件 - 增强调试和容错
    print(f"[表格选择] table_key={table_key}, selection类型={type(selection)}")
    
    selected_stocks = []
    
    # 尝试多种方式获取选中的行
    try:
        if selection is not None:
            # 方式1：直接访问 selection.rows
            if hasattr(selection, 'rows') and selection.rows:
                selected_indices = selection.rows
                print(f"[表格选择] 方式1成功: 选中行索引 = {selected_indices}")
            # 方式2：访问 selection.selection.rows
            elif hasattr(selection, 'selection') and hasattr(selection.selection, 'rows') and selection.selection.rows:
                selected_indices = selection.selection.rows
                print(f"[表格选择] 方式2成功: 选中行索引 = {selected_indices}")
            else:
                selected_indices = []
                print(f"[表格选择] 未检测到选中行, selection属性: {dir(selection)}")
            
            # 提取选中的股票信息
            for idx in selected_indices:
                try:
                    row = df_display.iloc[idx]
                    code = str(row['代码']).strip()
                    # 优先使用"股票"列，其次"名称"列
                    if '股票' in row and row['股票'] and str(row['股票']).strip():
                        name = str(row['股票']).strip()
                    elif '名称' in row and row['名称'] and str(row['名称']).strip():
                        name = str(row['名称']).strip()
                    else:
                        name = code
                    
                    selected_stocks.append((code, name))
                    print(f"[表格选择] 提取股票: {code} - {name}")
                except Exception as e:
                    print(f"[表格选择] ❌ 提取行{idx}失败: {e}")
    
    except Exception as e:
        print(f"[表格选择] ❌ 处理选择异常: {type(e).__name__}: {str(e)}")
    
    num_selected = len(selected_stocks)
    print(f"[表格选择] 最终选中数量: {num_selected}")
    
    # 【V87.7】显示操作按钮
    if num_selected > 0:
        col1, col2, col3 = st.columns(3)
        
        with col1:
            if num_selected == 1:
                code, name = selected_stocks[0]
                if st.button(f"🔍 分析 {name}", key=f"analyze_{table_key}", type="primary", use_container_width=True):
                    st.session_state.scan_selected_code = code
                    st.session_state.scan_selected_name = name
                    st.session_state.pk_codes = []
                    st.session_state.pk_names = []
                    st.toast(f"✅ 已选中 {name}", icon="🎯")
                    st.rerun()
            elif num_selected >= 2:
                if st.button(f"⚔️ 立即对比 {num_selected}只", key=f"compare_{table_key}", type="primary", use_container_width=True):
                    codes = [s[0] for s in selected_stocks]
                    names = [s[1] for s in selected_stocks]
                    st.session_state.pk_codes = codes
                    st.session_state.pk_names = names
                    st.session_state.scan_selected_code = None
                    st.session_state.scan_selected_name = None
                    st.toast(f"⚔️ 开始对比 {num_selected} 只股票", icon="⚔️")
                    st.rerun()
        
        with col2:
            # 【V87.7】加入对比篮
            if st.button(f"➕ 加入对比篮 ({num_selected}只)", key=f"add_basket_{table_key}", use_container_width=True):
                added_count = 0
                for code, name in selected_stocks:
                    if (code, name) not in st.session_state.compare_basket:
                        st.session_state.compare_basket.append((code, name))
                        added_count += 1
                if added_count > 0:
                    st.toast(f"✅ 已加入 {added_count} 只股票到对比篮", icon="➕")
                    st.rerun()
                else:
                    st.toast("ℹ️ 这些股票已在对比篮中", icon="ℹ️")
        
        with col3:
            # 清除选择
            if st.button("🗑️ 清除选择", key=f"clear_{table_key}", use_container_width=True):
                st.rerun()

# ═══════════════════════════════════════════════════════════════
# 14. 核心功能区 - 【V89.7 独立化】各Tab互不影响
# ═══════════════════════════════════════════════════════════════
tab_scanner, tab_quant, tab_portfolio = st.tabs(["📡 猎手战位", "🏆 Top30 扫描", "🛡️ 持仓管理"])

# 【V89.7】模块独立化 - 各Tab互不影响
with tab_scanner:
    st.markdown("#### 智能筛选引擎")
    
    # 【V87.1】显示股票池大小和来源（安全限流模式）
    us_count, hk_count, cn_count = len(RAW_US), len(RAW_HK), len(RAW_CN_TOP)
    total_count = us_count + hk_count + cn_count
    
    # 判断是否使用云端数据（阈值降低到50）
    is_cloud_us = us_count >= 50
    is_cloud_hk = hk_count >= 50
    is_cloud_cn = cn_count >= 50
    
    source_icon = "☁️" if (is_cloud_us and is_cloud_hk and is_cloud_cn) else "💾"
    source_text = "云端实时" if (is_cloud_us and is_cloud_hk and is_cloud_cn) else "本地备用"
    
    st.caption(f"{source_icon} **股票池来源**: {source_text} | 美股 {us_count} 只 | 港股 {hk_count} 只 | A股 {cn_count} 只 | 总计 {total_count} 只")
    
    # 初始化 session_state
    if 'scanner_results' not in st.session_state:
        st.session_state.scanner_results = {}
    # 【NEW V88 Phase 2】初始化取消标志
    if 'cancel_scan' not in st.session_state:
        st.session_state.cancel_scan = {'cancel': False}
    
    # 【V89.6.4】显示扫描缓存状态
    if 'scanner_results' in st.session_state and st.session_state.scanner_results:
        if 'scan_timestamp' in st.session_state.scanner_results:
            scan_time = st.session_state.scanner_results['scan_timestamp']
            scan_age = time.time() - scan_time
            remaining_hours = (86400 - scan_age) / 3600
            if remaining_hours > 0:
                scan_time_str = time.strftime('%H:%M:%S', time.localtime(scan_time))
                st.info(f"📦 使用缓存扫描结果 | 扫描时间: {scan_time_str} | 剩余有效期: {remaining_hours:.1f}小时")
            else:
                st.warning("⏰ 扫描缓存已过期（超过24小时），请重新扫描")
    
    # 【V89.6.4】添加清除缓存按钮
    clear_col1, clear_col2 = st.columns([3, 1])
    with clear_col2:
        if st.button("🗑️ 清除扫描缓存", help="清除所有扫描结果缓存", use_container_width=True):
            st.session_state.scanner_results = {}
            st.toast("✅ 扫描缓存已清除", icon="🗑️")
            st.rerun()
    
    # 【NEW V88 Phase 2】扫描辅助函数
    def run_scan(scan_type, ma_target, pool, use_concurrent, scan_name, icon):
        """统一的扫描执行函数"""
        st.session_state.cancel_scan = {'cancel': False}
        scan_mode = "⚡ 并发" if use_concurrent else "🔄 串行"
        st.toast(f"扫描 {scan_name}... ({scan_mode})", icon=icon)
        
        progress_bar = st.progress(0)
        status_text = st.empty()
        
        def update_progress(current, total, stock_name):
            progress = current / total
            progress_bar.progress(progress)
            mode_text = "并发扫描" if use_concurrent else "扫描"
            status_text.text(f"正在{mode_text}{scan_name}... {current}/{total} ({progress*100:.1f}%) - {stock_name}")
        
        if use_concurrent and USE_NEW_MODULES:
            res, stats = batch_scan_analysis_concurrent(
                pool, scan_type=scan_type, ma_target=ma_target,
                progress_callback=update_progress, max_workers=6,
                cancel_flag=st.session_state.cancel_scan
            )
        else:
            res, stats = batch_scan_analysis(
                pool, scan_type=scan_type, ma_target=ma_target,
                progress_callback=update_progress
            )
        
        progress_bar.empty()
        status_text.empty()
        
        if stats.get('cancelled', False):
            st.warning("⚠️ 扫描已取消")
        
        st.caption(f"✅ 成功扫描: {stats['success']} 只 | ❌ 失败/无数据: {stats['failed']} 只")
        
        if stats['failed'] > 0:
            display_scan_failures(stats['errors'], stats['failed'])
        
        return res, stats
    
    c_ctrl = st.container()
    with c_ctrl:
        # 【NEW V88 Phase 2】添加并发选项和取消按钮
        col_market, col_concurrent, col_cancel = st.columns([2, 2, 1])
        with col_market:
            scan_market = st.radio("市场", ["美股", "港股", "A股"], horizontal=True, label_visibility="collapsed")
        with col_concurrent:
            use_concurrent = st.checkbox("⚡ 并发扫描（6线程，速度快2-3倍）", value=False, help="使用多线程并发扫描，大幅提升速度")
        with col_cancel:
            if st.button("🛑 取消", help="取消当前扫描", use_container_width=True):
                st.session_state.cancel_scan['cancel'] = True
                st.toast("正在取消扫描...", icon="🛑")
        
        # 【V82.12】专业均线策略重构
        st.caption("💡 均线触底反弹策略：股价触及关键均线时，反弹概率大")
        c_btn1, c_btn2, c_btn3, c_btn4, c_btn5 = st.columns(5)
        
        do_scan_ma30 = c_btn1.button("📊 MA30短线", help="月线支撑，适合短线波段（3-7天）", use_container_width=True)
        do_scan_ma60 = c_btn2.button("📈 MA60季线", help="季线支撑，适合波段交易（1-3周）", use_container_width=True)
        do_scan_ma120 = c_btn3.button("📉 MA120半年", help="半年线支撑，适合中线布局（1-3月）", use_container_width=True)
        do_scan_top = c_btn4.button("🏆 综合评分", help="多维度量化评分，不限均线", type="primary", use_container_width=True)
        do_scan_safe = c_btn5.button("🛡️ 多重支撑", help="同时靠近多条均线，风险低", use_container_width=True)
    
    # 【V82.12 + NEW V88 Phase 2】重构扫描按钮逻辑（使用统一扫描函数）
    if do_scan_ma30:
        pool = RAW_US if scan_market == "美股" else (RAW_HK if scan_market == "港股" else RAW_CN_TOP)
        res, stats = run_scan("MA_TOUCH", 30, pool, use_concurrent, "MA30 短线反弹", "📊")
        
        st.session_state.scanner_results = {
            'type': 'ma30',
            'title': f"#### 📊 MA30 短线反弹 ({scan_market})",
            'caption': "💡 适合短线波段交易，持仓3-7天，快进快出捕捉超跌反弹",
            'data': res,
            'stats': stats,
            'key': 'ma30_table',
            'scan_timestamp': time.time()  # 【V89.6.4】添加扫描时间戳
        }
    
    if do_scan_ma60:
        pool = RAW_US if scan_market == "美股" else (RAW_HK if scan_market == "港股" else RAW_CN_TOP)
        res, stats = run_scan("MA_TOUCH", 60, pool, use_concurrent, "MA60 季线机会", "📈")
        
        st.session_state.scanner_results = {
            'type': 'ma60',
            'title': f"#### 📈 MA60 季线机会 ({scan_market})",
            'caption': "💡 适合波段交易，持仓1-3周，中期趋势确认，胜率更高",
            'data': res,
            'stats': stats,
            'key': 'ma60_table',
            'scan_timestamp': time.time()  # 【V89.6.4】添加扫描时间戳
        }
    
    if do_scan_ma120:
        pool = RAW_US if scan_market == "美股" else (RAW_HK if scan_market == "港股" else RAW_CN_TOP)
        res, stats = run_scan("MA_TOUCH", 120, pool, use_concurrent, "MA120 半年线布局", "📉")
        
        st.session_state.scanner_results = {
            'type': 'ma120',
            'title': f"#### 📉 MA120 半年线布局 ({scan_market})",
            'caption': "💡 适合价值投资，持仓1-3月，长期支撑位，适合分批建仓",
            'data': res,
            'stats': stats,
            'key': 'ma120_table',
            'scan_timestamp': time.time()  # 【V89.6.4】添加扫描时间戳
        }
    
    if do_scan_top:
        pool = RAW_US if scan_market == "美股" else (RAW_HK if scan_market == "港股" else RAW_CN_TOP)
        res, stats = run_scan("TOP", None, pool, use_concurrent, "综合评分 Top", "🏆")
        
        st.session_state.scanner_results = {
            'type': 'top',
            'title': f"#### 🏆 综合评分 Top 榜单 ({scan_market})",
            'caption': "💡 多维度量化评分：CANSLIM + 专业投机原理 + 技术指标，不限均线",
            'data': res,
            'stats': stats,
            'key': 'top_table',
            'scan_timestamp': time.time()  # 【V89.6.4】添加扫描时间戳
        }
    
    if do_scan_safe:
        st.toast("扫描多重均线支撑标的...", icon="🛡️")
        st.markdown("#### 🛡️ 多重均线支撑 (安全区)")
        st.caption("💡 同时靠近MA30/MA60/MA120，多重支撑共振，风险低，适合保守型投资者")
        
        # 【V87.17】添加进度条
        progress_bar = st.progress(0)
        status_text = st.empty()
        
        res_combined = []
        # 【V84.4】统计
        stats_safe = {'success': 0, 'failed': 0, 'errors': []}
        
        # 【V88修复】根据用户选择的市场决定扫描范围
        if scan_market == "美股":
            all_pools = [(RAW_US, "美股")]
        elif scan_market == "港股":
            all_pools = [(RAW_HK, "港股")]
        elif scan_market == "A股":
            all_pools = [(RAW_CN_TOP, "A股")]
        else:
            all_pools = [(RAW_US, "美股"), (RAW_HK, "港股"), (RAW_CN_TOP, "A股")]
        
        # 计算总股票数
        total_stocks = sum(len(pool) for pool, _ in all_pools)
        current_idx = 0
        
        for pool, mkt_label in all_pools:
            for idx, item in enumerate(pool):
                # 【V87.17】更新进度条
                current_idx += 1
                progress_pct = current_idx / total_stocks
                progress_bar.progress(progress_pct)
                stock_name = item[1] if len(item) > 1 else item[0]
                status_text.text(f"正在扫描 {stock_name}... ({current_idx}/{total_stocks}, {progress_pct*100:.1f}%)")
                # 【V84.3】每个股票都用try-except包裹
                try:
                    code = item[0]
                    name = item[1]
                    # 【V82.9关键修复】如果pool有3个元素，直接使用第3个
                    if len(item) >= 3:
                        c_fixed = item[2]
                    else:
                        c_fixed = to_yf_cn_code(code)
                    
                    # 【V87.1】添加请求间隔，避免触发API限流（每10个股票延迟0.5秒）
                    if idx > 0 and idx % 10 == 0:
                        time.sleep(0.5)
                    
                    df = fetch_stock_data(c_fixed)
                    
                    # 【V84.3】防御性检查
                    if df is None or df.empty:
                        stats_safe['failed'] += 1
                        continue
                    
                    m = calculate_metrics_all(df, c_fixed)
                    # 【V86修复】多重均线支撑：同时靠近MA30/MA60/MA120
                    # 降低评分要求，放宽容差
                    if m and m['score'] > 35:  # 【V86】从45降到35
                        last_close = m['last']['Close']
                        last_low = m['last']['Low']
                        last_high = m['last']['High']
                        touch_count = 0
                        touch_mas = []
                        
                        for ma_n in [30, 60, 120]:
                            ma_col = f'MA{ma_n}'
                            if ma_col in m['df'].columns:
                                ma_val = m['df'][ma_col].iloc[-1]
                                # 【V86】放宽容差到8%，或者K线触及均线
                                touched = (last_low <= ma_val <= last_high)
                                close_enough = (ma_val > 0 and abs(last_close - ma_val) / ma_val < 0.08)
                                
                                if touched or close_enough:
                                    touch_count += 1
                                    distance_pct = abs(last_close - ma_val) / ma_val * 100 if ma_val > 0 else 0
                                    touch_mas.append(f"MA{ma_n}({distance_pct:.1f}%)")
                        
                        # 【V86】打印调试信息
                        if touch_count >= 2:
                            print(f"[多重支撑] ✅ {code} ({name}): 触及{touch_count}条均线 - {', '.join(touch_mas)}, 评分={m['score']}")
                        
                        # 只有触及2条或以上均线才算"多重支撑"
                        if touch_count >= 2:
                            res_combined.append({
                                "市场": mkt_label, "代码": code, "名称": name,
                                "评分": m['score'], "策略": m['logic'],
                                "现价": f"{m['last_price']:.2f}",
                                "触发": " + ".join(touch_mas)
                            })
                            stats_safe['success'] += 1
                except Exception as e:
                    stats_safe['failed'] += 1
                    error_msg = f"{type(e).__name__}: {str(e)[:80]}"
                    stats_safe['errors'].append({
                        'code': item[0] if item else 'Unknown',
                        'name': item[1] if len(item) > 1 else 'Unknown',
                        'error': error_msg
                    })
        
        # 【V87.17】清除进度条
        progress_bar.empty()
        status_text.empty()
        
        # 【V85】显示统计和失败详情
        st.caption(f"✅ 成功扫描: {stats_safe['success']} 只 | ❌ 失败/无数据: {stats_safe['failed']} 只")
        
        # 【V87.8】如果有失败的股票,显示详情
        if stats_safe['failed'] > 0:
            display_scan_failures(stats_safe['errors'], stats_safe['failed'])
        
        res_combined = sorted(res_combined, key=lambda x: x['评分'], reverse=True)[:50]
        st.session_state.scanner_results = {
            'type': 'safe_zone',
            'title': "#### 🛡️ 多重均线支撑 (安全区)",
            'caption': "💡 同时靠近MA30/MA60/MA120，多重支撑共振，风险低，适合保守型投资者",
            'data': res_combined,
            'stats': stats_safe,
            'key': 'safe_zone',
            'scan_timestamp': time.time()  # 【V89.6.4】添加扫描时间戳
        }
    
    # 【V82.12】显示保存的扫描结果（支持caption）
    if st.session_state.scanner_results:
        result_info = st.session_state.scanner_results
        
        # 【NEW V88 Phase 2】标题和导出按钮并排
        col_title, col_export = st.columns([4, 1])
        with col_title:
            st.markdown(result_info['title'])
            if 'caption' in result_info and result_info['caption']:
                st.caption(result_info['caption'])
        with col_export:
            # 【NEW V88 Phase 2】CSV导出功能
            if result_info['data']:
                df_export = pd.DataFrame(result_info['data'])
                csv = df_export.to_csv(index=False, encoding='utf-8-sig')
                st.download_button(
                    label="📥 导出CSV",
                    data=csv,
                    file_name=f"scan_{result_info['type']}_{pd.Timestamp.now().strftime('%Y%m%d_%H%M%S')}.csv",
                    mime="text/csv",
                    help="下载扫描结果为CSV文件",
                    use_container_width=True
                )
        
        # 【NEW V88 Phase 2】表格筛选功能
        df_results = pd.DataFrame(result_info['data'])
        
        if not df_results.empty:
            # 筛选器
            col_filter1, col_filter2 = st.columns(2)
            
            with col_filter1:
                # 板块筛选
                if '板块' in df_results.columns:
                    sectors = ['全部'] + sorted(df_results['板块'].unique().tolist())
                    selected_sector = st.selectbox("🏷️ 筛选板块", sectors, key=f"filter_sector_{result_info['key']}")
                    if selected_sector != '全部':
                        df_results = df_results[df_results['板块'] == selected_sector]
            
            with col_filter2:
                # 得分筛选
                if '得分' in df_results.columns:
                    min_score = st.slider(
                        "📊 最低得分",
                        min_value=0,
                        max_value=100,
                        value=0,
                        step=5,
                        key=f"filter_score_{result_info['key']}",
                        help="只显示得分≥此值的股票"
                    )
                    df_results = df_results[df_results['得分'] >= min_score]
            
            # 显示筛选后的结果数量
            if len(df_results) < len(result_info['data']):
                st.caption(f"🔍 筛选后: {len(df_results)} 只 / 总共 {len(result_info['data'])} 只")
        
        render_clickable_table(df_results, result_info['key'])
    
    st.divider()
    st.markdown("---")
with tab_quant:
    # 【V87.13】标题改为小字体
    st.markdown('<p style="font-size: 18px; font-weight: 600; margin-bottom: 0.5rem;">🏆 核心资产批量扫描 (Top 30)</p>', unsafe_allow_html=True)
    
    # 【V87.13】三市场并列扫描
    col_scan1, col_scan2 = st.columns([3, 1])
    
    with col_scan1:
        scan_mode = st.radio("扫描模式", ["🚀 全市场扫描 (中美港Top30)", "📊 单市场扫描"], horizontal=True)
    
    with col_scan2:
        if scan_mode == "🚀 全市场扫描 (中美港Top30)":
            scan_button_text = "🚀 开始全市场扫描"
            scan_button_type = "primary"
        else:
            mkt = st.selectbox("选择市场", ["美股", "港股", "A股"])
            scan_button_text = f"📊 扫描{mkt}"
            scan_button_type = "secondary"
    
    # 初始化 session_state
    if 'quant_results_us' not in st.session_state:
        st.session_state.quant_results_us = None
    if 'quant_results_hk' not in st.session_state:
        st.session_state.quant_results_hk = None
    if 'quant_results_cn' not in st.session_state:
        st.session_state.quant_results_cn = None
    if 'scan_timestamp' not in st.session_state:
        st.session_state.scan_timestamp = None
    
    if st.button(scan_button_text, type=scan_button_type, use_container_width=True):
        if scan_mode == "🚀 全市场扫描 (中美港Top30)":
            # 【V87.4修复】简化扫描流程，避免多线程UI问题
            import time
            
            start_time = time.time()
            
            with st.spinner("🚀 正在扫描中美港三市场..."):
                # 创建进度条
                progress_bar = st.progress(0)
                status_text = st.empty()
                
                # 准备扫描数据
                markets_data = [
                    ("美股", RAW_US),
                    ("港股", RAW_HK), 
                    ("A股", RAW_CN_TOP)
                ]
                
                # 【V87.14】顺序扫描，使用详细进度显示
                for idx, (market_name, pool) in enumerate(markets_data):
                    # 更新市场进度
                    market_progress = idx / 3
                    progress_bar.progress(market_progress)
                    
                    # 定义该市场的进度回调
                    def update_market_progress(current, total, stock_name):
                        # 计算总进度：市场进度 + 当前市场内进度
                        total_progress = (idx + current / total) / 3
                        progress_bar.progress(total_progress)
                        status_text.text(f"正在扫描{market_name}... {current}/{total} ({current/total*100:.1f}%) - {stock_name}")
                    
                    try:
                        # 【V87.15修复】从完整股票池扫描，然后筛选Top30
                        results, stats = batch_scan_analysis(pool, scan_type="TOP", progress_callback=update_market_progress)
                        
                        # 【V87.4调试】显示原始结果数量
                        print(f"[扫描调试] {market_name} 原始结果: {len(results)}条")
                        
                        # 【V87.4修复】放宽过滤条件，只过滤明显无效的数据
                        valid_results = []
                        for r in results:
                            # 检查必要字段
                            if (r.get('股票') and r.get('股票') != 'N/A' and 
                                r.get('代码') and r.get('代码') != 'N/A' and
                                r.get('得分', 0) >= 0):  # 允许0分，只排除负分或无分数
                                valid_results.append(r)
                        
                        # 【V87.15】按得分排序，取Top30
                        valid_results = sorted(valid_results, key=lambda x: x.get('得分', 0), reverse=True)[:30]
                        
                        print(f"[扫描调试] {market_name} Top30结果: {len(valid_results)}条")
                        
                        # 保存结果（即使为空也保存，便于调试）
                        if market_name == "美股":
                            st.session_state.quant_results_us = valid_results
                        elif market_name == "港股":
                            st.session_state.quant_results_hk = valid_results
                        elif market_name == "A股":
                            st.session_state.quant_results_cn = valid_results
                        
                        # 更新进度
                        progress_bar.progress((idx + 1) / 3)
                        
                        # 显示详细状态
                        if len(valid_results) > 0:
                            status_text.text(f"✅ {market_name}扫描完成 ({len(valid_results)}只有效)")
                        else:
                            status_text.text(f"⚠️ {market_name}扫描完成 (0只有效，{stats.get('failed', 0)}只失败)")
                        
                    except Exception as e:
                        print(f"[扫描错误] {market_name}: {str(e)}")
                        st.error(f"❌ {market_name}扫描失败: {str(e)}")
                        progress_bar.progress((idx + 1) / 3)
                
                # 记录扫描时间
                st.session_state.scan_timestamp = time.time()
                elapsed_time = time.time() - start_time
                
                progress_bar.progress(1.0)
                status_text.success(f"✅ 全市场扫描完成！用时 {elapsed_time:.1f} 秒")
                
        else:
            # 单市场扫描
            pool = RAW_US if mkt == "美股" else (RAW_HK if mkt == "港股" else RAW_CN_TOP)
            
            # 【V87.14】添加进度显示
            progress_bar = st.progress(0)
            status_text = st.empty()
            
            def update_single_market_progress(current, total, stock_name):
                progress = current / total
                progress_bar.progress(progress)
                status_text.text(f"扫描 {mkt}... {current}/{total} ({progress*100:.1f}%) - {stock_name}")
            
            # 【V87.15修复】从完整股票池扫描，然后筛选Top30
            res, stats = batch_scan_analysis(pool, scan_type="TOP", progress_callback=update_single_market_progress)
            
            # 【V87.15】按得分排序，取Top30
            res = sorted(res, key=lambda x: x.get('得分', 0), reverse=True)[:30]
            
            progress_bar.empty()
            status_text.empty()
            
            # 保存结果到对应市场
            if mkt == "美股":
                st.session_state.quant_results_us = res
            elif mkt == "港股":
                st.session_state.quant_results_hk = res
            else:
                st.session_state.quant_results_cn = res
    
    # 【V87.4】三列显示扫描结果 + 缓存机制
    st.divider()
    
    # 检查缓存时效（10分钟）
    cache_valid = False
    if st.session_state.scan_timestamp:
        cache_age = (time.time() - st.session_state.scan_timestamp) / 60  # 分钟
        cache_valid = cache_age < 10
        if cache_valid:
            st.caption(f"📊 **缓存数据** (更新于 {cache_age:.1f} 分钟前，{10-cache_age:.1f} 分钟后过期)")
        else:
            st.caption("⏰ **缓存已过期**，建议重新扫描获取最新数据")
    
    # 显示三列结果
    if (st.session_state.quant_results_us or st.session_state.quant_results_hk or st.session_state.quant_results_cn):
        # 【V87.13】标题和股票池信息并排显示
        col_title_left, col_pool_info = st.columns([3, 1])
        with col_title_left:
            st.markdown('<p style="font-size: 16px; font-weight: 600; margin-bottom: 0.5rem;">🏆 全球市场 Top30 扫描结果</p>', unsafe_allow_html=True)
        with col_pool_info:
            # 【V87.13】股票池信息 - 小字体，右对齐
            us_count, hk_count, cn_count = len(RAW_US), len(RAW_HK), len(RAW_CN_TOP)
            total_count = us_count + hk_count + cn_count
            source_icon = "☁️" if total_count > 600 else "💾"
            source_text = "云端实时数据" if total_count > 600 else "本地备用池"
            st.markdown(f'<div style="text-align: right; font-size: 10px; color: #6b7280; line-height: 1.4;">{source_icon} {source_text} (10分钟缓存)<br/>美股 {us_count} | 港股 {hk_count} | A股 {cn_count} | 总计 {total_count} 只<br/>⚡ 安全模式: 680只&lt;800安全线</div>', unsafe_allow_html=True)
        
        col_us, col_hk, col_cn = st.columns(3)
        
        with col_us:
            st.markdown('<p style="font-size: 14px; font-weight: 600; margin-bottom: 0.5rem;">🇺🇸 美股 Top30</p>', unsafe_allow_html=True)
            if st.session_state.quant_results_us is not None:
                us_results = st.session_state.quant_results_us
                if len(us_results) > 0:
                    us_df = pd.DataFrame(us_results)
                    # 确保必要列存在
                    required_cols = ['股票', '代码', '得分', '建议']
                    available_cols = [col for col in required_cols if col in us_df.columns]
                    
                    if available_cols:
