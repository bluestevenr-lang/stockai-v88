#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
本地测试钉钉推送功能
运行前请先配置环境变量或直接在脚本中填写
"""

import os

# ═══════════════════════════════════════════════════════════════
# 配置区域（请填写你的信息）
# ═══════════════════════════════════════════════════════════════
# 方式1：直接在这里填写（测试用）
GEMINI_API_KEY_TEST = ""  # 填写你的 Gemini API Key
DINGTALK_WEBHOOK_TEST = ""  # 填写你的钉钉 Webhook URL
DINGTALK_SECRET_TEST = ""  # 填写你的钉钉 Secret

# 方式2：从环境变量读取（推荐）
if not GEMINI_API_KEY_TEST:
    GEMINI_API_KEY_TEST = os.environ.get('AIzaSyD6jDteDoTA3FzD5aLYYqKagazb4iQSUd0', '')
if not DINGTALK_WEBHOOK_TEST:
    DINGTALK_WEBHOOK_TEST = os.environ.get('https://oapi.dingtalk.com/robot/send?access_token=a06fce0541a9ad9d4fb3a0ebc26596805594d9750d33c06044bfa05e15bbbe7e', '')
if not DINGTALK_SECRET_TEST:
    DINGTALK_SECRET_TEST = os.environ.get('SEC26debefd8a1b6b5a0af03e3a8e5451b17d53e563b0a91819cda32f07d0c525be', '')

# ═══════════════════════════════════════════════════════════════
# 设置环境变量并运行测试
# ═══════════════════════════════════════════════════════════════
if __name__ == "__main__":
    print("="*60)
    print("🧪 钉钉推送功能测试")
    print("="*60)
    
    # 检查配置
    config_ok = True
    
    if not GEMINI_API_KEY_TEST:
        print("❌ 缺少 GEMINI_API_KEY")
        config_ok = False
    else:
        print(f"✅ GEMINI_API_KEY: {GEMINI_API_KEY_TEST[:10]}...")
    
    if not DINGTALK_WEBHOOK_TEST:
        print("❌ 缺少 DINGTALK_WEBHOOK")
        config_ok = False
    else:
        print(f"✅ DINGTALK_WEBHOOK: {DINGTALK_WEBHOOK_TEST[:50]}...")
    
    if not DINGTALK_SECRET_TEST:
        print("❌ 缺少 DINGTALK_SECRET")
        config_ok = False
    else:
        print(f"✅ DINGTALK_SECRET: {DINGTALK_SECRET_TEST[:10]}...")
    
    if not config_ok:
        print("\n" + "="*60)
        print("❌ 配置不完整，请先填写配置信息")
        print("="*60)
        print("\n编辑此文件，填写以下变量：")
        print("  - GEMINI_API_KEY_TEST")
        print("  - DINGTALK_WEBHOOK_TEST")
        print("  - DINGTALK_SECRET_TEST")
        exit(1)
    
    print("\n" + "="*60)
    print("🚀 开始测试...")
    print("="*60 + "\n")
    
    # 设置环境变量
    os.environ['GEMINI_API_KEY'] = GEMINI_API_KEY_TEST
    os.environ['DINGTALK_WEBHOOK'] = DINGTALK_WEBHOOK_TEST
    os.environ['DINGTALK_SECRET'] = DINGTALK_SECRET_TEST
    
    # 导入并运行主程序
    try:
        import auto_reporter
        auto_reporter.main()
        
        print("\n" + "="*60)
        print("✅ 测试完成！请检查钉钉群是否收到消息")
        print("="*60)
        
    except Exception as e:
        print("\n" + "="*60)
        print(f"❌ 测试失败: {type(e).__name__}: {str(e)}")
        print("="*60)
        import traceback
        traceback.print_exc()
