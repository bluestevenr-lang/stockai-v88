# V88 StockAI 环境变量模板
# ─────────────────────────────────────────────────────────────────────────────
# 使用方法：
#   cp .env.example .env
#   open -e .env     （填入真实值）
#
# .env 已加入 .gitignore，不会上传 GitHub。
# Streamlit Cloud 请在云端 Dashboard → Secrets 单独维护。
# ─────────────────────────────────────────────────────────────────────────────

# ── Google Gemini AI ──────────────────────────────────────────────────────────
# 生成新 Key：https://aistudio.google.com/app/apikey
GEMINI_API_KEY=你的Gemini_API_Key

# ── Tushare（A股/港股数据）───────────────────────────────────────────────────
# 获取 Token：https://tushare.pro/user/token
TUSHARE_TOKEN=你的Tushare_Token

# ── GitHub Gist（自选股同步）─────────────────────────────────────────────────
# GIST_ID：Gist 页面 URL 最后一段
GIST_ID=你的Gist_ID
# GIST_TOKEN：可选，用于读取私有 Gist 或提高 API 速率限制
# 生成：GitHub → Settings → Developer settings → Personal access tokens → gist
GIST_TOKEN=

# ── 钉钉机器人 ───────────────────────────────────────────────────────────────
# DingTalk 群 → 智能群助手 → 添加自定义机器人
DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=你的access_token
DINGTALK_SECRET=SEC你的签名密钥
DINGTALK_KEYWORD=股票行情
